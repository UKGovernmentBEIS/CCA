        <design:display_ref_in_diagram>true</design:display_ref_in_diagram>
      </extensionElements>
    </exclusiveGateway>
    <intermediateCatchEvent id="IntermediateTimerEvent_2" name="timer event">
      <extensionElements>
        <design:stencilid>IntermediateTimerEvent</design:stencilid>
        <design:display_ref_in_diagram>true</design:display_ref_in_diagram>
      </extensionElements>
      <timerEventDefinition>
        <timeDuration>PT1S</timeDuration>
      </timerEventDefinition>
    </intermediateCatchEvent>
    <startEvent id="StartEvent_1" flowable:formFieldValidation="false">
      <extensionElements>
