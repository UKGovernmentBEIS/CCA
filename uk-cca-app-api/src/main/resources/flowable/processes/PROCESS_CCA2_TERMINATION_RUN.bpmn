      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="Flow_1xqlhqa" sourceRef="Gateway_0eg5738" targetRef="ServiceTask_9">
      <extensionElements>
        <design:stencilid>SequenceFlow</design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression">${accountIds.size() > 0}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_0b19fou" sourceRef="Gateway_0eg5738" targetRef="Activity_06604vf">
      <extensionElements>
        <flowable:is-default-flow>true</flowable:is-default-flow>
        <design:stencilid>SequenceFlow</design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_10" name="yes" sourceRef="Exclusive_Databased_Gateway_7" targetRef="Activity_06604vf">
      <extensionElements>
        <design:stencilid>SequenceFlow</design:stencilid>
        <design:display_ref_in_diagram>true</design:display_ref_in_diagram>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression">${accountsCompleted == accountIds.size()}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_11" name="no" sourceRef="Exclusive_Databased_Gateway_7" targetRef="IntermediateTimerEvent_2">
      <extensionElements>
        <design:stencilid>SequenceFlow</design:stencilid>
        <design:display_ref_in_diagram>true</design:display_ref_in_diagram>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression">${accountsCompleted &lt; accountIds.size()}</conditionExpression>
    </sequenceFlow>
