  <process id="PROCESS_CCA2_TERMINATION_RUN" name="CCA2 Termination Run Process" isExecutable="true">
    <extensionElements>
      <design:stencilid>BPMNDiagram</design:stencilid>
      <design:creationdate>2026-01-20T12:21:28.883Z</design:creationdate>
      <design:modificationdate>2026-01-21T13:21:52.616Z</design:modificationdate>
    </extensionElements>
    <serviceTask id="Activity_0lpi6k4" name="Trigger cca2 termination account processing" flowable:delegateExpression="#{cca2TerminationAccountsProcessingTriggerHandlerFlowable}">
      <extensionElements>
        <design:stencilid>ServiceTask</design:stencilid>
        <design:stencilsuperid>Task</design:stencilsuperid>
      </extensionElements>
      <multiInstanceLoopCharacteristics isSequential="false" flowable:collection="accountIds" flowable:elementVariable="accountId">
        <extensionElements></extensionElements>
      </multiInstanceLoopCharacteristics>
    </serviceTask>
    <serviceTask id="Activity_06604vf" name="cca2 termination run completed" flowable:async="true" flowable:delegateExpression="#{cca2TerminationRunCompletedHandlerFlowable}">
      <extensionElements>
        <design:stencilid>ServiceTask</design:stencilid>
        <design:stencilsuperid>Task</design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceTask_8" name="Populate accounts completed number" flowable:delegateExpression="#{cca2TerminationRunNumberOfAccountsCompletedHandlerFlowable}">
      <extensionElements>
        <design:stencilid>ServiceTask</design:stencilid>
        <design:stencilsuperid>Task</design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <serviceTask id="ServiceTask_9" name="Terminate in progress variation requests" flowable:delegateExpression="#{cca2TerminationRunTerminateVariationRequestsHandlerFlowable}">
      <extensionElements>
        <design:stencilid>ServiceTask</design:stencilid>
        <design:stencilsuperid>Task</design:stencilsuperid>
      </extensionElements>
