<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/changelog_buy_out_fees.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="0_1_0_TPR_BUY_OUY_SURPLUS_EXCLUSION_SEQUENCE" author="vourdoukasd@unisystems.gr">
        <createSequence
                sequenceName="tpr_buy_out_surplus_exclusion_seq"
                minValue="0"
                maxValue="999999999999999999"
                incrementBy="1"
                startValue="1"
                cycle="false"/>
        <rollback>
            <dropSequence sequenceName="tpr_buy_out_surplus_exclusion_seq"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_BUY_OUT_SURPLUS_EXCLUSION" author="vourdoukasd">
        <comment>Buy-out surplus exclusion accounts Table. All end dates (deadlines) are inclusive</comment>
        <createTable tableName="tpr_buy_out_surplus_exclusion" remarks="Represents the buy out surplus exclusion accounts">
        <column name="id" type="bigint" remarks="Primary key">
            <constraints primaryKey="true" primaryKeyName="tpr_buy_out_surplus_exclusion_pk" nullable="false"/>
        </column>
        <column name="account_id" type="bigint" remarks="Represents the account id">
            <constraints unique="true" uniqueConstraintName="tpr_buy_out_surplus_exclusion_accountId_uq" nullable="false"/>
        </column>
    </createTable>
        <rollback>
            <dropTable tableName="tpr_buy_out_surplus_exclusion" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_BUY_OUT_SURPLUS_sequence" author="P70383">
        <createSequence
                sequenceName="tpr_buy_out_surplus_seq"
                minValue="0"
                maxValue="999999999999999999"
                incrementBy="1"
                startValue="1"
                cycle="false"/>
        <rollback>
            <sql>
                DROP SEQUENCE IF EXISTS tpr_buy_out_surplus_seq;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_BUY_OUT_SURPLUS_CREATE_TABLE" author="P70383">
        <comment>Create buy out surplus table</comment>
        <createTable tableName="tpr_buy_out_surplus"
                     remarks="Represents the buy out surplus for performance data results">
            <column name="id" type="bigint" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="tpr_buy_out_surplus_pk"
                             nullable="false"/>
            </column>
            <column name="performance_data_id" type="bigint" remarks="The performance data id value">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="transaction_id" type="varchar(20)" remarks="The transaction ID">
                <constraints nullable="true" unique="true"/>
            </column>
            <column name="buy_out_fee" type="numeric" remarks="The current buy out fee value">
                <constraints nullable="false"/>
            </column>
            <column name="payment_status" type="varchar(20)" remarks="The payment status">
                <constraints nullable="true"/>
            </column>
            <column name="data" type="jsonb" remarks="The metrics as calculated during the buy-out and surplus batch run">
                <constraints nullable="false" />
            </column>
            <column name="file_document_uuid" type="varchar(255)" remarks="The notice's file document uuid">
                <constraints nullable="true" />
            </column>
            <column name="creation_date" type="timestamp" remarks="The date creation of the buy out surplus">
                <constraints nullable="false" />
            </column>
        </createTable>
        <rollback>
            <sql>
                DROP TABLE IF EXISTS tpr_buy_out_surplus CASCADE;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_BUY_OUT_TRANSACTION_IDENTIFIER_CREATE_TABLE" author="P70383">
        <comment>Create buy out transaction identifier table</comment>
        <createTable tableName="tpr_buy_out_transaction_identifier" remarks="Represents the latest transaction identifier value">
            <column name="id" type="integer" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="tpr_buy_out_transaction_identifier_pk" nullable="false"/>
            </column>
            <column name="target_period_type" type="varchar(20)" remarks="The target period type">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="transaction_id" type="bigint" remarks="The sequential number">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <sql>
                DROP TABLE IF EXISTS tpr_buy_out_transaction_identifier CASCADE;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_SURPLUS_sequence" author="vourdoukasd">
        <createSequence sequenceName="tpr_surplus_seq"
                        incrementBy="1"
                        startValue="1"
                        minValue="0"
                        cycle="false"
                        maxValue="999999999999999999" />
        <rollback>
            <dropSequence sequenceName="tpr_surplus_seq"/>
        </rollback>
    </changeSet>
    
    <changeSet id="0_1_0_TPR_SURPLUS_CREATE_TABLE" author="vourdoukasd">
        <createTable tableName="tpr_surplus" remarks="Represents the surplus table">
            <column name="id" type="bigint" remarks="Primary key" >
                <constraints primaryKey="true" primaryKeyName="tpr_surplus_pk" nullable="false"/>
            </column>
            <column name="account_id" type="bigint" remarks="Represents the account id">
                <constraints nullable="false"/>
            </column>
            <column name="target_period_id" type="bigint" remarks="Represents the target period id">
                <constraints foreignKeyName="target_period_id_fk" references="tpr_target_period(id)" nullable="false"/>
            </column>
            <column name="surplus_gained" type="numeric" remarks="Represents the surplus gained" >
                <constraints nullable="false" />
            </column>
        </createTable>
        <addUniqueConstraint tableName="tpr_surplus"
                             columnNames="account_id, target_period_id"
                             constraintName="tpr_surplus_account_id_target_period_id_uq"
        />
        <rollback>
            <dropTable tableName="tpr_surplus" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_SURPLUS_HISTORY_sequence" author="vourdoukasd">
        <createSequence sequenceName="tpr_surplus_history_seq"
                        incrementBy="1"
                        startValue="1"
                        minValue="0"
                        cycle="false"
                        maxValue="999999999999999999" />
        <rollback>
            <dropSequence sequenceName="tpr_surplus_history_seq"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_SURPLUS_HISTORY_CREATE_TABLE" author="vourdoukasd">
        <createTable tableName="tpr_surplus_history"  remarks="Represents the surplus history table">
            <column name="id" type="bigint" remarks="Primary key" >
                <constraints primaryKey="true" primaryKeyName="tpr_surplus_history_pk" nullable="false"/>
            </column>
            <column name="surplus_id" type="bigint" remarks="Represents the surplus id">
                <constraints foreignKeyName="surplus_id_fk" references="tpr_surplus(id)" nullable="false"/>
            </column>
            <column name="new_surplus_gained" type="numeric" remarks="Represents the new surplus gained" >
                <constraints nullable="false" />
            </column>
            <column name="comments" type="TEXT" remarks="Represents the comments of the user"/>
            <column name="submitter_id" type="varchar(255)" remarks="Represents the submitter id">
                <constraints nullable="true" />
            </column>
            <column name="submitter" type="varchar(255)" remarks="Represents the submitter name">
                <constraints nullable="true" />
            </column>
            <column name="submission_date" type="timestamp" remarks="Represents the submission date of surplus history data entry">
                <constraints nullable="false" />
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="tpr_surplus_history" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_SURPLUS_HISTORY_update_submitter_to_required" author="P70383">
        <addNotNullConstraint tableName="tpr_surplus_history" columnName="submitter"/>
        <rollback>
            <dropNotNullConstraint tableName="tpr_surplus_history" columnName="submitter"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_DROP_TABLE" author="P70383">
        <comment>Drop buy out surplus table</comment>
        <dropTable tableName="tpr_buy_out_surplus" cascadeConstraints="true"/>
        <dropSequence sequenceName="tpr_buy_out_surplus_seq"/>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_transaction_sequence" author="P70383">
        <createSequence sequenceName="tpr_buy_out_surplus_transaction_seq"
                        incrementBy="1"
                        startValue="1"
                        minValue="0"
                        cycle="false"
                        maxValue="999999999999999999" />
        <rollback>
            <dropSequence sequenceName="tpr_buy_out_surplus_transaction_seq"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_transaction_CREATE_TABLE" author="P70383">
        <comment>Create buy out surplus transaction table</comment>
        <createTable tableName="tpr_buy_out_surplus_transaction"  remarks="Represents the buy out surplus transaction table">
            <column name="id" type="bigint" remarks="Primary key" >
                <constraints primaryKey="true" primaryKeyName="tpr_buy_out_surplus_transaction_pk" nullable="false"/>
            </column>
            <column name="performance_data_id" type="bigint" remarks="The performance data id value">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="transaction_code" type="varchar(20)" remarks="The transaction code">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="buy_out_fee" type="numeric" remarks="The current buy out fee value">
                <constraints nullable="false"/>
            </column>
            <column name="payment_status" type="varchar(20)" remarks="The payment status">
                <constraints nullable="false"/>
            </column>
            <column name="data" type="jsonb" remarks="The metrics as calculated during the buy-out and surplus batch run">
                <constraints nullable="false" />
            </column>
            <column name="file_document_uuid" type="varchar(255)" remarks="The notice's file document uuid">
                <constraints nullable="false" />
            </column>
            <column name="creation_date" type="timestamp" remarks="The date creation of the transaction">
                <constraints nullable="false" />
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="tpr_buy_out_surplus_transaction" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_TPR_BUY_OUT_TRANSACTION_IDENTIFIER_RENAME_TABLE" author="P70383">
        <comment>Rename to buy out surplus transaction identifier table</comment>
        <renameTable newTableName="tpr_buy_out_surplus_transaction_identifier" oldTableName="tpr_buy_out_transaction_identifier" />
        <rollback>
            <renameTable newTableName="tpr_buy_out_transaction_identifier" oldTableName="tpr_buy_out_surplus_transaction_identifier" />
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_processed_data_SEQUENCE" author="P70383">
        <createSequence
                sequenceName="tpr_buy_out_surplus_processed_data_seq"
                minValue="0"
                maxValue="999999999999999999"
                incrementBy="1"
                startValue="1"
                cycle="false"/>
        <rollback>
            <dropSequence sequenceName="tpr_buy_out_surplus_processed_data_seq"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_processed_data_CREATE_TABLE" author="P70383">
        <comment>Create buy out surplus processed data table</comment>
        <createTable tableName="tpr_buy_out_surplus_processed_data" remarks="Represents the buy out surplus processed data from batch run">
            <column name="id" type="bigint" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="tpr_buy_out_surplus_processed_data_pk" nullable="false"/>
            </column>
            <column name="performance_data_id" type="bigint" remarks="The performance data id value">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="creation_date" type="timestamp" remarks="The date creation">
                <constraints nullable="false" />
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="tpr_buy_out_surplus_processed_data" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_transaction_history_sequence" author="P70383">
        <createSequence sequenceName="tpr_buy_out_surplus_transaction_history_seq"
                        incrementBy="1"
                        startValue="1"
                        minValue="0"
                        cycle="false"
                        maxValue="999999999999999999" />
        <rollback>
            <dropSequence sequenceName="tpr_buy_out_surplus_transaction_history_seq"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_transaction_history_CREATE_TABLE" author="P70383">
        <comment>Create buy out surplus transaction history table</comment>
        <createTable tableName="tpr_buy_out_surplus_transaction_history"  remarks="Represents the buy out surplus transaction history table">
            <column name="id" type="bigint" remarks="Primary key" >
                <constraints primaryKey="true" primaryKeyName="tpr_buy_out_surplus_transaction_history_pk" nullable="false"/>
            </column>
            <column name="buy_out_surplus_transaction_id" type="bigint" remarks="The buy out surplus transaction id">
                <constraints foreignKeyName="buy_out_surplus_transaction_id_fk" references="tpr_buy_out_surplus_transaction(id)" nullable="false"/>
            </column>
            <column name="payload" type="jsonb" remarks="The historical data">
                <constraints nullable="false"/>
            </column>
            <column name="submitter_id" type="varchar(255)" remarks="The submitter id">
                <constraints nullable="true" />
            </column>
            <column name="submitter" type="varchar(255)" remarks="The submitter name">
                <constraints nullable="false" />
            </column>
            <column name="submission_date" type="timestamp" remarks="The submission date of data entry">
                <constraints nullable="false" />
            </column>
        </createTable>
        <sql>
            ALTER TABLE tpr_buy_out_surplus_transaction_history
                ADD COLUMN change_type varchar(64)
                    GENERATED ALWAYS AS ((payload ->> 'type')::text) STORED;
        </sql>
        <rollback>
            <dropTable tableName="tpr_buy_out_surplus_transaction_history" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_tpr_buy_out_surplus_transaction_add_column_payment_date" author="vourdoukasd@unisystems.gr">
        <addColumn tableName="tpr_buy_out_surplus_transaction">
            <column name="payment_date" type="date" remarks="The payment date for buy out transaction"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="tpr_buy_out_surplus_transaction" columnName="payment_date" />
        </rollback>
    </changeSet>
    

</databaseChangeLog>