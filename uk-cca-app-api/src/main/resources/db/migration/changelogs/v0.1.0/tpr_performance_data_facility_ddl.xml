<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/tpr_performance_data_facility_ddl.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
     http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="0_1_0_create_tpr_performance_data_facility_sequence" author="P70383">
        <createSequence sequenceName="tpr_performance_data_facility_seq" minValue="0" maxValue="999999999999999999"
                        incrementBy="1" startValue="1" cycle="false"/>
        <rollback>
            <sql>
                DROP SEQUENCE IF EXISTS tpr_performance_data_facility_seq;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_create_table_tpr_performance_data_facility" author="P70383">
        <createTable tableName="tpr_performance_data_facility" remarks="Represents performance data facility submission data">
            <column name="id" type="bigint" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="tpr_performance_data_facility_pk"
                             nullable="false"/>
            </column>
            <column name="data" type="jsonb" remarks="performance data facility representation as json">
                <constraints nullable="false"/>
            </column>
            <column name="target_period_id" type="bigint" remarks="Foreign key referencing tpr_target_period">
                <constraints foreignKeyName="target_period_id_fk" references="tpr_target_period(id)" nullable="false"/>
            </column>
            <column name="target_period_year" type="int" remarks="The reporting target period year">
                <constraints nullable="false"/>
            </column>
            <column name="facility_id" type="bigint" remarks="The facility identifier">
                <constraints nullable="false"/>
            </column>
            <column name="report_version" type="int" defaultValueNumeric="1" remarks="The reporting version">
                <constraints nullable="false"/>
            </column>
            <column name="submission_type" type="varchar(64)" remarks="The reporting submission type">
                <constraints nullable="true"/>
            </column>
            <column name="submission_date" type="timestamp" remarks="The submission date of performance data facility">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql>
            ALTER TABLE tpr_performance_data_facility
                ADD COLUMN performance_outcome varchar(64)
                    GENERATED ALWAYS AS ((data -> 'calculatedResults' ->> 'targetPeriodResultType')::text) STORED;
        </sql>
        <addUniqueConstraint
                tableName="tpr_performance_data_facility"
                columnNames="target_period_year, facility_id, report_version"
                constraintName="tpr_performance_data_facility_uc"/>
        <rollback>
            <sql>
                DROP TABLE IF EXISTS tpr_performance_data_facility CASCADE;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_create_tpr_performance_data_facility_status_sequence" author="P70383">
        <createSequence sequenceName="tpr_performance_data_facility_status_seq" minValue="0" maxValue="999999999999999999"
                        incrementBy="1" startValue="1" cycle="false"/>
        <rollback>
            <sql>
                DROP SEQUENCE IF EXISTS tpr_performance_data_facility_status_seq;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_create_table_tpr_performance_data_facility_status" author="P70383">
        <createTable tableName="tpr_performance_data_facility_status"
                     remarks="Represents performance data facility status for locking and data version tracking">
            <column name="id" type="bigint" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="tpr_performance_data_facility_status_pk"
                             nullable="false"/>
            </column>
            <column name="target_period_id" type="bigint" remarks="Foreign key referencing tpr_target_period">
                <constraints foreignKeyName="target_period_id_fk" references="tpr_target_period(id)" nullable="false"/>
            </column>
            <column name="target_period_year" type="int" remarks="The reporting target period year">
                <constraints nullable="false"/>
            </column>
            <column name="facility_id" type="bigint" remarks="The facility identifier">
                <constraints nullable="false"/>
            </column>
            <column name="locked" type="boolean" defaultValueBoolean="false" remarks="Flag indicating whether facility is locked for submitting new performance data"/>
            <column name="variation_indicator" type="boolean" defaultValueBoolean="false" remarks="Flag indicating whether the variation modifies facility baseline and targets"/>
            <column name="last_performance_data_id" type="bigint" remarks="The last version of the performance data uploaded">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="tpr_performance_data_facility_status"
                columnNames="target_period_year, facility_id"
                constraintName="tpr_performance_data_facility_status_uc"/>
        <rollback>
            <sql>
                DROP TABLE IF EXISTS tpr_performance_data_facility_status CASCADE;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>