    <changeSet id="0_1_0_ACCOUNT_TARGET_UNIT_IDENTIFIER_CREATE_TABLE" author="P70628">
        <comment>Create target unit account identifier table</comment>
        <createTable tableName="account_target_unit_identifier" remarks="Represents the latest tager unit account id value">
            <column name="id" type="integer" remarks="Primary key">
                <constraints primaryKey="true" primaryKeyName="account_target_unit_identifier_pk" nullable="false"/>
            </column>
            <column name="account_id" type="bigint" remarks="The latest account id value">
                <constraints nullable="false"/>
            </column>
            <column name="sector_association_id" type="bigint" remarks="The latest sector association id value">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <sql>
                DROP TABLE IF EXISTS account_target_unit_identifier CASCADE;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_ADD_UNIQUE_CONSTRAINT_ACCOUNT_TARGET_UNIT_IDENTIFIER_TABLE" author="P70628">
        <preConditions onFail="MARK_RAN">
            <not>
                <uniqueConstraintExists tableName="account_target_unit_identifier" constraintName="account_target_unit_identifier_uc"/>
            </not>
        </preConditions>
        <addUniqueConstraint tableName="account_target_unit_identifier" columnNames="sector_association_id,account_id" constraintName="account_target_unit_identifier_uc"/>
        <rollback>
            <dropUniqueConstraint tableName="account_target_unit_identifier" constraintName="account_target_unit_identifier_uc"/>
        </rollback>
    </changeSet>

    <changeSet id="0_1_0_INITIALIZE_ACCOUNT_TARGET_UNIT_IDENTIFIER_TABLE" author="P70628">
        <comment>Initialize target unit account identifier table with max emitter id from sector_association table</comment>
        <sql>
            INSERT INTO account_target_unit_identifier(id, account_id, sector_association_id)
            SELECT nextval('account_target_unit_identifier_seq'),
                   count(atu.id) as account_id, sa.id as sector_association_id FROM sector_association sa
                       LEFT JOIN account_target_unit atu ON sa.id = atu.sector_association_id GROUP BY sa.id;
        </sql>
    </changeSet>

