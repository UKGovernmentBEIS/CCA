    <changeSet id="0_1_0_ACCOUNT_TARGET_UNIT_IDENTIFIER_SEQUENCE" author="P70628">
        <createSequence sequenceName="account_target_unit_identifier_seq" minValue="0" maxValue="999999999999999999"
