<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/facility_audit_ddl.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

<changeSet id="0_1_0_FACILITY_AUDIT_SEQUENCE" author="vourdoukasd">
    <createSequence sequenceName="facility_audit_id_seq" cycle="false" incrementBy="1" minValue="0"
                    maxValue="999999999999999999" startValue="1"/>
    <rollback>
        <dropSequence sequenceName="facility_audit_id_seq"/>
    </rollback>
</changeSet>

<changeSet id="0_1_0_FACILITY_AUDIT_TABLE_CREATION" author="vourdoukasd">
    <createTable tableName="facility_audit" remarks="Represents a facility audit flag table">
        <column name="id" type="bigint" remarks="The id of the facility_audit">
            <constraints primaryKey="true" primaryKeyName="facility_audit_id_pk" nullable="false"/>
        </column>
        <column name="facility_id" type="bigint" remarks="The id of the facility">
            <constraints nullable="false" unique="true"/>
        </column>
        <column name="further_audit_required" type="boolean" remarks="The facility audit flag" defaultValueBoolean="false">
            <constraints nullable="false"/>
        </column>
        <column name="reasons" type="jsonb" remarks="The reasons of the facility audit as json"/>
        <column name="comments"  type="varchar(10000)"/>
        <column name="last_updated_on" type="timestamp" remarks="The date and time of the last update"/>
        <column name="updated_by" type="varchar(255)" remarks="The user id"/>
    </createTable>

    <rollback>
        <dropTable tableName="facility_audit" cascadeConstraints="true" />
    </rollback>
</changeSet>

<changeSet id="0_1_0_FACILITY_AUDIT_TABLE_rename_further_audit_required" author="vourdoukasd">
    <renameColumn tableName="facility_audit" oldColumnName="further_audit_required" newColumnName="audit_required"/>
</changeSet>
    

</databaseChangeLog>