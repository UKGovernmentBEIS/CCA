      <bpmn:sequenceFlow id="Flow_1128ib6" name="yes" sourceRef="Gateway_1sr4tz1" targetRef="Event_0yhcv20">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${accountIds.size() == accountsCompleted}</bpmn:conditionExpression>
