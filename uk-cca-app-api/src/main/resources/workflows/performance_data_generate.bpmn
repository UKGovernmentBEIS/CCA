  <bpmn:process id="PROCESS_PERFORMANCE_DATA_GENERATE" name="Reporting spreadsheets generate process" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_0jekkyo</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0lpi6k4" name="trigger spreadsheet generate" camunda:asyncBefore="true" camunda:delegateExpression="#{performanceDataSpreadsheetGenerateTriggerHandler}">
      <bpmn:incoming>Flow_0jekkyo</bpmn:incoming>
      <bpmn:outgoing>Flow_0s0zu9j</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="accountIds" camunda:elementVariable="accountId" />
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_088wx5f" name="performance data generation completed">
      <bpmn:incoming>Flow_0s0zu9j</bpmn:incoming>
