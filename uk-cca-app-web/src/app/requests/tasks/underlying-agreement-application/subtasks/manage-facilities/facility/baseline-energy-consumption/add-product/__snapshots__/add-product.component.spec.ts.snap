</label><!--container--><select govukformerror="" class="govuk-select govuk-!-width-one-quarter ng-untouched ng-pristine ng-valid" id="products.0.baselineYear" name="products.0.baselineYear"><option value="0: 2022"> 2022 </option><option value="1: 2023"> 2023 </option><option value="2: 2024"> 2024 </option><option value="3: 2025"> 2025 </option><option value="4: 2026"> 2026 </option><option value="5: 2027"> 2027 </option><option value="6: 2028"> 2028 </option><option value="7: 2029"> 2029 </option><option value="8: 2030"> 2030 </option><!--container--></select></div><div formcontrolname="baselineVariableEnergy" govuk-text-input="" widthclass="govuk-!-width-one-quarter" label="Baseline variable energy" hint="This value may be entered as zero" inputtype="number" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="products.0.baselineVariableEnergy" id="l.products.0.baselineVariableEnergy"> Baseline variable energy </label><!--container--><div class="govuk-hint" id="products.0.baselineVariableEnergy-hint"> This value may be entered as zero </div><!--container--><!--container--><div class="govuk-input__wrapper"><!--container--><input class="govuk-input govuk-!-width-one-quarter" autocomplete="on" id="products.0.baselineVariableEnergy" name="products.0.baselineVariableEnergy" type="text"><!--container--><div aria-hidden="true" class="govuk-input__suffix">kWh</div><!--container--></div><!--container--><!--container--><!--container--></div><div formcontrolname="baselineThroughput" widthclass="govuk-!-width-one-quarter" govuk-text-input="" label="Baseline year throughput" hint="For facilities where SRM is used, this must be the adjusted throughput" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="products.0.baselineThroughput" id="l.products.0.baselineThroughput"> Baseline year throughput </label><!--container--><div class="govuk-hint" id="products.0.baselineThroughput-hint"> For facilities where SRM is used, this must be the adjusted throughput </div><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-quarter" autocomplete="on" id="products.0.baselineThroughput" name="products.0.baselineThroughput" type="text"><!--container--><!--container--><!--container--></div><div formcontrolname="throughputUnit" widthclass="govuk-!-width-one-quarter" govuk-text-input="" label="Throughput unit" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="products.0.throughputUnit" id="l.products.0.throughputUnit"> Throughput unit </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-quarter" autocomplete="on" id="products.0.throughputUnit" name="products.0.throughputUnit" type="text"><!--container--><!--container--><!--container--></div><div class="govuk-form-group govuk-!-margin-top-4"><p class="govuk-label govuk-label--s">Energy intensity</p><p class="govuk-hint">Automatically calculated</p><p class="govuk-body govuk-!-margin-bottom-0"> 2 kWh/tonnes <!--container--><!--container--></p></div></div></cca-add-product-item></div><!--container--><!--ng-container--><div class="govuk-button-group govuk-grid-row"><div class="govuk-grid-column-full"><button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-5"> Add another product </button></div><div class="govuk-grid-column-full govuk-!-margin-top-5"><button type="submit" class="govuk-button">Update table</button></div></div></form>"
