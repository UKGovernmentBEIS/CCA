// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FacilityDetailsComponent > should render the form with the correct initial values 1`] = `
"<cca-facility-details-form><cca-wizard-step heading="Facility details" class="ng-untouched ng-pristine ng-invalid"><form novalidate="" class="ng-untouched ng-pristine ng-invalid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l">Facility details</h1></netz-page-heading><div class="govuk-!-width-two-thirds"><div formcontrolname="name" govuk-text-input="" label="Site name" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"><!--container--><label class="govuk-label" for="name" id="l.name"> Site name </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-full" autocomplete="on" disabled="" id="name" name="name" type="text"><!--container--><!--container--><!--container--></div><!--container--><div formcontrolname="isCoveredByUkets" govuk-radio="" legend="Are the activities carried out by this facility included in the UKETS?" hint="If some or all of the activities carried out in this facility are regulated activities under the UK ETS scheme, you must enter the UK ETS permit identifier" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><div class="govuk-form-group"><fieldset govukfieldset="" id="isCoveredByUkets" aria-describedby="isCoveredByUkets-hint" class="govuk-fieldset"><legend govuklegend="" id="l.isCoveredByUkets" class="govuk-fieldset__legend"> Are the activities carried out by this facility included in the UKETS? <!--container--><!--container--></legend><div govukfieldsethint="" class="govuk-hint" id="isCoveredByUkets-hint">If some or all of the activities carried out in this facility are regulated activities under the UK ETS scheme, you must enter the UK ETS permit identifier</div><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="isCoveredByUkets-option0" value="true" aria-controls="isCoveredByUkets-option0-conditional" name="isCoveredByUkets"><label class="govuk-label govuk-radios__label" for="isCoveredByUkets-option0"> Yes <!--container--><!--container--></label><!--container--></div><!--ng-container--><div class="govuk-radios__conditional govuk-radios__conditional--hidden" id="isCoveredByUkets-option0-conditional"><div widthclass="govuk-!-width-one-third" formcontrolname="uketsId" govuk-text-input="" label="UK ETS installation/permit Identifier" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"><!--container--><label class="govuk-label" for="uketsId" id="l.uketsId"> UK ETS installation/permit Identifier </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="on" disabled="" id="uketsId" name="uketsId" type="text"><!--container--><!--container--><!--container--></div><!--ng-container--></div><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="isCoveredByUkets-option1" value="false" name="isCoveredByUkets"><label class="govuk-label govuk-radios__label" for="isCoveredByUkets-option1"> No <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><div formcontrolname="applicationReason" govuk-radio="" legend="Application reason" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"><div class="govuk-form-group"><fieldset govukfieldset="" id="applicationReason" class="govuk-fieldset"><legend govuklegend="" id="l.applicationReason" class="govuk-fieldset__legend"> Application reason <!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" disabled="" id="applicationReason-option0" value="NEW_AGREEMENT" name="applicationReason"><label class="govuk-label govuk-radios__label" for="applicationReason-option0"> New entrant <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" disabled="" id="applicationReason-option1" value="CHANGE_OF_OWNERSHIP" name="applicationReason"><label class="govuk-label govuk-radios__label" for="applicationReason-option1"> Change of ownership <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><!--container--><div class="govuk-!-margin-bottom-9"><p class="govuk-!-margin-bottom-0">Scheme participation</p><p class="govuk-hint govuk-!-margin-top-1"> This indicates whether the facility participates in CCA2 (2013-2024), CCA3 (2026-2030) or both </p><p></p></div><h2 class="govuk-heading-m">Facility address</h2><p>The facility address must be in England, Scotland, Wales or Northern Ireland</p><!--container--><div formgroupname="facilityAddress" class="ng-untouched ng-pristine ng-invalid"><cca-facility-address-input><div govuk-text-input="" autocomplete="address-line1" formcontrolname="line1" label="Address line 1" widthclass="govuk-!-width-two-thirds" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><!--container--><label class="govuk-label" for="facilityAddress.line1" id="l.facilityAddress.line1"> Address line 1 </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-two-thirds" autocomplete="address-line1" id="facilityAddress.line1" name="facilityAddress.line1" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="address-line2" formcontrolname="line2" label="Address line 2 (optional)" widthclass="govuk-!-width-two-thirds" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="facilityAddress.line2" id="l.facilityAddress.line2"> Address line 2 (optional) </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-two-thirds" autocomplete="address-line2" id="facilityAddress.line2" name="facilityAddress.line2" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="address-level2" formcontrolname="city" label="Town or city" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><!--container--><label class="govuk-label" for="facilityAddress.city" id="l.facilityAddress.city"> Town or city </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="address-level2" id="facilityAddress.city" name="facilityAddress.city" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="county" formcontrolname="county" label="County (optional)" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="facilityAddress.county" id="l.facilityAddress.county"> County (optional) </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="county" id="facilityAddress.county" name="facilityAddress.county" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="postal-code" formcontrolname="postcode" label="Postcode" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><!--container--><label class="govuk-label" for="facilityAddress.postcode" id="l.facilityAddress.postcode"> Postcode </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="postal-code" id="facilityAddress.postcode" name="facilityAddress.postcode" type="text"><!--container--><!--container--><!--container--></div><div govuk-select="" formcontrolname="country" label="Country" labelsize="small" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><label class="govuk-label" for="facilityAddress.country" id="l.facilityAddress.country"> Country
</label><!--container--><select govukformerror="" class="govuk-select ng-untouched ng-pristine ng-invalid" id="facilityAddress.country" name="facilityAddress.country"><!--container--></select></div></cca-facility-address-input></div></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/">Return to: Manage facilities</a></cca-facility-details-form>"
`;
