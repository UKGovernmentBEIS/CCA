// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DeleteProductComponent > should render the delete confirmation 1`] = `"<netz-page-heading><span class="govuk-caption-l">Facility 1</span><!--container--><h1 class="govuk-heading-l"> Are you sure you want to delete Product 1? </h1></netz-page-heading><p> When you submit the "Baseline energy or carbon consumption" page, your product and all its data will be deleted permanently </p><govuk-warning-text assistivetext=""><div class="govuk-warning-text"><span aria-hidden="true" class="govuk-warning-text__icon">!</span><strong class="govuk-warning-text__text"><span class="govuk-warning-text__assistive"></span>You will not be able to undo this action.</strong></div></govuk-warning-text><button class="govuk-button govuk-button--warning">Delete product</button>"`;
