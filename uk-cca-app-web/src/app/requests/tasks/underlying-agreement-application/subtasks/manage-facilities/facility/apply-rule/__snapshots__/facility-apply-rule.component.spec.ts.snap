// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FacilityApplyRuleComponent > should show form values 1`] = `"<cca-wizard-step heading="Apply the 70% rule" data-testid="facility-extend-form" class="ng-untouched ng-pristine ng-invalid"><form novalidate="" class="ng-untouched ng-pristine ng-invalid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l">Apply the 70% rule</h1></netz-page-heading><div class="govuk-!-width-two-thirds"><div formcontrolname="energyConsumed" govuk-text-input="" inputtype="number" label="Energy consumed in the installation" hint="Enter the amount of energy consumed by the eligible activities and any directly associated activities (the installation) over a recent 12 month period as a percentage of the total energy used by the site over the same period. Enter a number between 0% and 100%." suffix="%" widthclass="govuk-input--width-5" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><!--container--><label class="govuk-label" for="energyConsumed" id="l.energyConsumed"> Energy consumed in the installation </label><!--container--><div class="govuk-hint" id="energyConsumed-hint"> Enter the amount of energy consumed by the eligible activities and any directly associated activities (the installation) over a recent 12 month period as a percentage of the total energy used by the site over the same period. Enter a number between 0% and 100%. </div><!--container--><!--container--><div class="govuk-input__wrapper"><!--container--><input class="govuk-input govuk-input--width-5" autocomplete="on" id="energyConsumed" name="energyConsumed" type="text"><!--container--><div aria-hidden="true" class="govuk-input__suffix">%</div><!--container--></div><!--container--><!--container--><!--container--></div><!--container--><p>Energy consumed in eligible facility</p><!--container--><!--container--><cca-file-input formcontrolname="evidenceFile" hint="Upload data that supports any estimations and shows any formulas used" label="Evidence" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><div class="cca-multi-file-upload cca-multi-file-upload--enhanced"><label class="govuk-label" id="l.evidenceFile" for="evidenceFile">Evidence</label><!--container--><!--container--><span class="govuk-hint govuk-!-display-block" id="evidenceFile-hint">Upload data that supports any estimations and shows any formulas used</span><!--container--><!--container--><input type="file" class="govuk-file-upload" accept="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" id="evidenceFile" name="evidenceFile"><cca-file-upload-list><div class="cca-multi-file__uploaded-files cca-hidden"><!--container--><!--container--><dl class="govuk-summary-list"><!--container--></dl><!--container--><!--container--><!--container--><!--container--><!--container--></div><!--container--></cca-file-upload-list></div></cca-file-input></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step><!--container--><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/"> Return to: Manage facilities </a>"`;
