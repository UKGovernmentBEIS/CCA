// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FacilityContactDetailsComponent > should show form values 1`] = `
"<cca-wizard-step heading="Facility contact details" data-testid="add-facility-contact-form" class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><span class="govuk-caption-l">Facility 1</span><!--container--><h1 class="govuk-heading-l">Facility contact details</h1></netz-page-heading><div formcontrolname="sameContact" govuk-checkboxes="" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><fieldset govukfieldset="" id="sameContact" class="govuk-fieldset"><legend govuklegend="" id="l.sameContact" class="govuk-fieldset__legend govuk-fieldset__legend--l"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-checkboxes"><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="sameContact-0" name="sameContact" aria-describedby="sameContact-0-item-hint" value="true"><label class="govuk-label govuk-checkboxes__label" for="sameContact-0"> The facility contact details are the same as the target unit administrative contact details <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div><h2 class="govuk-heading-m">Name</h2><div formcontrolname="firstName" govuk-text-input="" label="First name" widthclass="govuk-!-width-one-half" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="firstName" id="l.firstName"> First name </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-half" autocomplete="on" id="firstName" name="firstName" type="text"><!--container--><!--container--><!--container--></div><div formcontrolname="lastName" govuk-text-input="" label="Last name" widthclass="govuk-!-width-one-half" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="lastName" id="l.lastName"> Last name </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-half" autocomplete="on" id="lastName" name="lastName" type="text"><!--container--><!--container--><!--container--></div><div formcontrolname="email" govuk-text-input="" inputtype="email" label="Email address" widthclass="govuk-!-width-one-half" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="email" id="l.email"> Email address </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-half" autocomplete="on" id="email" name="email" type="email"><!--container--><!--container--><!--container--></div><h2 class="govuk-heading-m">Address</h2><div formcontrolname="sameAddress" govuk-checkboxes="" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><fieldset govukfieldset="" id="sameAddress" class="govuk-fieldset"><legend govuklegend="" id="l.sameAddress" class="govuk-fieldset__legend govuk-fieldset__legend--l"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-checkboxes"><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="sameAddress-0" name="sameAddress" aria-describedby="sameAddress-0-item-hint" value="true"><label class="govuk-label govuk-checkboxes__label" for="sameAddress-0"> Use the facility address <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div><div formgroupname="address" class="ng-untouched ng-pristine ng-valid"><cca-account-address-input><div govuk-text-input="" autocomplete="address-line1" formcontrolname="line1" label="Address line 1" widthclass="govuk-!-width-two-thirds" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="address.line1" id="l.address.line1"> Address line 1 </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-two-thirds" autocomplete="address-line1" id="address.line1" name="address.line1" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="address-line2" formcontrolname="line2" label="Address line 2 (optional)" widthclass="govuk-!-width-two-thirds" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="address.line2" id="l.address.line2"> Address line 2 (optional) </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-two-thirds" autocomplete="address-line2" id="address.line2" name="address.line2" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="address-level2" formcontrolname="city" label="Town or city" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="address.city" id="l.address.city"> Town or city </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="address-level2" id="address.city" name="address.city" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="county" formcontrolname="county" label="County (optional)" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="address.county" id="l.address.county"> County (optional) </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="county" id="address.county" name="address.county" type="text"><!--container--><!--container--><!--container--></div><div govuk-text-input="" autocomplete="postal-code" formcontrolname="postcode" label="Postcode" widthclass="govuk-!-width-one-third" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label" for="address.postcode" id="l.address.postcode"> Postcode </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-one-third" autocomplete="postal-code" id="address.postcode" name="address.postcode" type="text"><!--container--><!--container--><!--container--></div><div govuk-select="" ccacountries="" formcontrolname="country" label="Country" labelsize="small" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><label class="govuk-label" for="address.country" id="l.address.country"> Country
</label><!--container--><select govukformerror="" class="govuk-select ng-untouched ng-pristine ng-valid" id="address.country" name="address.country"><option value="0: "> -- </option><!--container--></select></div></cca-account-address-input></div><h2 class="govuk-heading-m">Phone number</h2><div cca-phone-input="" formcontrolname="phoneNumber" label="Phone number 1" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><fieldset govukfieldset="" id="fieldset" class="govuk-fieldset"><legend govuklegend="" hidden="">Phone number 1</legend><span govukfieldsethint=""></span><!--container--><div class="govuk-grid-row ng-untouched ng-pristine ng-valid"><div class="govuk-grid-column-one-quarter"><div class="govuk-form-group"><label class="govuk-label" for="phoneNumber.countryCode" id="l.phoneNumber">Country code</label><select autocomplete="tel-country-code" formcontrolname="countryCode" class="govuk-select ng-untouched ng-pristine ng-valid" id="phoneNumber.countryCode" name="phoneNumber.countryCode"><option value="">--</option><!--container--></select><!--container--></div></div><div class="govuk-grid-column-one-half"><div class="govuk-form-group"><label class="govuk-label" for="phoneNumber">Phone number 1</label><input autocomplete="tel-national" formcontrolname="number" type="tel" class="govuk-input govuk-!-width-full ng-untouched ng-pristine ng-valid" id="phoneNumber" name="phoneNumber"><!--container--><!--container--></div></div></div></fieldset></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/"> Return to: Manage facilities </a><!--container-->"
`;
