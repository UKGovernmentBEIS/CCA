exports[`FacilityEligibilityDetailsComponent > should test that the form renders properly 1`] = `
"<cca-wizard-step heading="CCA eligibility details and authorisation" data-testid="add-facility-eligibility-details-form" class="ng-untouched ng-pristine ng-invalid"><form novalidate="" class="ng-untouched ng-pristine ng-invalid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l">CCA eligibility details and authorisation</h1></netz-page-heading><div class="govuk-!-width-two-thirds"><div formcontrolname="isConnectedToExistingFacility" govuk-radio="" legend="Is the facility adjacent to or connected to an existing CCA facility?" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><div class="govuk-form-group"><fieldset govukfieldset="" id="isConnectedToExistingFacility" class="govuk-fieldset"><legend govuklegend="" id="l.isConnectedToExistingFacility" class="govuk-fieldset__legend"> Is the facility adjacent to or connected to an existing CCA facility? <!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="isConnectedToExistingFacility-option0" value="true" aria-controls="isConnectedToExistingFacility-option0-conditional" name="isConnectedToExistingFacility"><label class="govuk-label govuk-radios__label" for="isConnectedToExistingFacility-option0"> Yes <!--container--><!--container--></label><!--container--></div><!--ng-container--><div class="govuk-radios__conditional govuk-radios__conditional--hidden" id="isConnectedToExistingFacility-option0-conditional"><div widthclass="govuk-!-width-one-half" formcontrolname="adjacentFacilityId" cca-text-input="" label="Specify facility ID of adjacent facility" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"><label class="govuk-label" for="adjacentFacilityId" id="l.adjacentFacilityId"> Specify facility ID of adjacent facility <!--container--><!--container--></label><!--container--><!--container--><!--container--><!--container--><p>  </p><!--container--><!--container--><!--container--></div><!--ng-container--></div><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="isConnectedToExistingFacility-option1" value="false" name="isConnectedToExistingFacility"><label class="govuk-label govuk-radios__label" for="isConnectedToExistingFacility-option1"> No <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><div class="govuk-!-width-three-quarters"><label for="agreementType"> What is the legal basis for this facility being considered an eligible activity? </label><p class="govuk-hint"> Activities carried out in facilities are considered to be eligible if they are or would be regulated under the Environmental Permitting Regulations (EPR), or, they are part of a sector that has been identified as energy intensive </p><div widthclass="govuk-!-width-full" formcontrolname="agreementType" govuk-select="" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><label class="govuk-label govuk-visually-hidden" for="agreementType" id="l.agreementType"> Select
</label><!--container--><select govukformerror="" class="govuk-select govuk-!-width-full ng-untouched ng-pristine ng-invalid" id="agreementType" name="agreementType"><option value="0: ENVIRONMENTAL_PERMITTING_REGULATIONS"> Environmental Permitting Regulations (EPR) </option><option value="1: ENERGY_INTENSIVE"> Energy Intensive </option><!--container--></select></div></div><!--container--></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step><!--container--><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/"> Return to: Manage facilities </a>"
`;
