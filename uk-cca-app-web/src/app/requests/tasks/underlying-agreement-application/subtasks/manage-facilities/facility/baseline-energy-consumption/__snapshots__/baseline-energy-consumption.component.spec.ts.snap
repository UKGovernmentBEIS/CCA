// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`BaselineEnergyConsumptionComponent > should render the form with the correct initial values 1`] = `"<cca-wizard-step heading="Baseline energy or carbon" data-testid="baseline-energy-consumption-form" class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l">Baseline energy or carbon</h1></netz-page-heading><div class="govuk-grid-row"><p class="govuk-grid-column-two-thirds"> The baseline energy or carbon refers to the energy consumed or carbon dioxide emitted in the 12 month period from the Start date of the baseline. The targets set for the facility will be the percentage improvement in energy efficiency or carbon dioxide efficiency from this base year. </p></div><div class="govuk-grid-row govuk-!-margin-top-7"><div class="govuk-grid-column-two-thirds"><p class="govuk-!-margin-bottom-0"> Enter the fixed amount of energy consumed (or carbon dioxide emitted) during the baseline </p><p class="govuk-hint govuk-!-margin-top-1"> Fixed energy consumption is the portion of a facility's total energy consumed (or carbon dioxide emitted) that does not vary with throughput. This value may be entered as zero </p><div govuk-text-input="" formcontrolname="totalFixedEnergy" inputtype="number" widthclass="govuk-!-width-one-half" class="govuk-!-width-one-half govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label govuk-visually-hidden" for="totalFixedEnergy" id="l.totalFixedEnergy">  </label><!--container--><!--container--><!--container--><div class="govuk-input__wrapper"><!--container--><input class="govuk-input govuk-!-width-one-half" autocomplete="on" id="totalFixedEnergy" name="totalFixedEnergy" type="text"><!--container--><div aria-hidden="true" class="govuk-input__suffix">kWh</div><!--container--></div><!--container--><!--container--><!--container--></div></div></div><div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><div formcontrolname="hasVariableEnergy" govuk-radio="" legend="Should any of the energy consumed (or carbon dioxide emitted) during the baseline be categorised as variable" hint="Variable energy consumption is the portion of a facility’s total energy consumed (or carbon dioxide emitted) that is related to throughput" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="hasVariableEnergy" aria-describedby="hasVariableEnergy-hint" class="govuk-fieldset"><legend govuklegend="" id="l.hasVariableEnergy" class="govuk-fieldset__legend"> Should any of the energy consumed (or carbon dioxide emitted) during the baseline be categorised as variable <!--container--><!--container--></legend><div govukfieldsethint="" class="govuk-hint" id="hasVariableEnergy-hint">Variable energy consumption is the portion of a facility’s total energy consumed (or carbon dioxide emitted) that is related to throughput</div><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="hasVariableEnergy-option0" value="true" name="hasVariableEnergy"><label class="govuk-label govuk-radios__label" for="hasVariableEnergy-option0"> Yes <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="hasVariableEnergy-option1" value="false" name="hasVariableEnergy"><label class="govuk-label govuk-radios__label" for="hasVariableEnergy-option1"> No <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div></div></div><div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><div formcontrolname="variableEnergyType" govuk-radio="" legend="Indicate how you want to account for the portion of variable energy used (or carbon dioxide emitted) for your facility" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="variableEnergyType" class="govuk-fieldset"><legend govuklegend="" id="l.variableEnergyType" class="govuk-fieldset__legend"> Indicate how you want to account for the portion of variable energy used (or carbon dioxide emitted) for your facility <!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios govuk-radios--inline"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="variableEnergyType-option0" value="TOTALS" name="variableEnergyType"><label class="govuk-label govuk-radios__label" for="variableEnergyType-option0"> Totals only <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="variableEnergyType-option1" value="BY_PRODUCT" name="variableEnergyType"><label class="govuk-label govuk-radios__label" for="variableEnergyType-option1"> Split by product <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div></div></div><!--container--><div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><div govuk-text-input="" formcontrolname="baselineVariableEnergy" label="Total baseline variable energy" labelsize="small" hint="This value may be entered as zero" inputtype="number" widthclass="govuk-!-width-one-half" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label govuk-label--s" for="baselineVariableEnergy" id="l.baselineVariableEnergy"> Total baseline variable energy </label><!--container--><div class="govuk-hint" id="baselineVariableEnergy-hint"> This value may be entered as zero </div><!--container--><!--container--><div class="govuk-input__wrapper"><!--container--><input class="govuk-input govuk-!-width-one-half" autocomplete="on" id="baselineVariableEnergy" name="baselineVariableEnergy" type="text"><!--container--><div aria-hidden="true" class="govuk-input__suffix">kWh</div><!--container--></div><!--container--><!--container--><!--container--></div></div></div><!--container--><!--container--><div class="govuk-grid-row"><div class="govuk-grid-column-full"><p class="govuk-label--s govuk-!-margin-bottom-0">Total baseline throughput</p><p class="govuk-hint govuk-!-margin-top-1"> For facilities where SRM is used, this must be the adjusted throughput </p></div><div class="govuk-grid-column-one-quarter"><div govuk-text-input="" formcontrolname="totalThroughput" inputtype="number" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label govuk-visually-hidden" for="totalThroughput" id="l.totalThroughput">  </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-full" autocomplete="on" id="totalThroughput" name="totalThroughput" type="text"><!--container--><!--container--><!--container--></div></div></div><div class="govuk-grid-row"><div class="govuk-grid-column-one-third"><div govuk-text-input="" formcontrolname="throughputUnit" label="Throughput unit" labelsize="small" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><!--container--><label class="govuk-label govuk-label--s" for="throughputUnit" id="l.throughputUnit"> Throughput unit </label><!--container--><!--container--><!--container--><!--container--><input class="govuk-input govuk-!-width-full" autocomplete="on" id="throughputUnit" name="throughputUnit" type="text"><!--container--><!--container--><!--container--></div></div></div><!--container--><div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><div class="govuk-form-group govuk-!-margin-top-2"><p class="govuk-label govuk-label--s">Energy intensity</p><p class="govuk-body govuk-!-margin-bottom-0"> 4 kWh/tonnes <!--container--><!--container--></p></div></div></div><!--container--><div class="govuk-grid-row govuk-!-margin-bottom-3"><div class="govuk-grid-column-two-thirds grey-background"><p class="govuk-label--m">Baseline year 2022 calculated energy amounts</p><p class="govuk-label--s">Fixed baseline energy for the facility</p><p>100.1234567 kWh</p><p class="govuk-label--s">Variable baseline energy for the facility</p><p>200 kWh</p><hr class="govuk-!-margin-bottom-3"><p class="govuk-label--s">Baseline total energy for the facility</p><p>300.1234567 kWh</p></div><div class="govuk-grid-column-one-third"><!--container--></div></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/"> Return to: Manage facilities </a>"`;
