"<div><netz-page-heading><!--container--><h1 class="govuk-heading-l">Variation details</h1></netz-page-heading><cca-summary><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Changes that don't usually require the operator to provide their assent</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Amend the 70% rule evaluation for one or more facilities</span><!--container--><br><!--container--><!--container--><span>Amend the target currency to change the throughput unit</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/variation-details?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Explain in more detail what you are changing and the reason for the changes</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Variation reason</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/variation-details?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary><cca-wizard-step class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l"></h1></netz-page-heading><cca-decision><h2 class="govuk-heading-m">What is your decision on the information submitted?</h2><span class="govuk-hint">Use your judgement to make minor changes within the details if needed</span><div govuk-radio="" formcontrolname="type" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="type" class="govuk-fieldset"><legend govuklegend="" id="l.type" class="govuk-fieldset__legend"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option0" value="ACCEPTED" name="type"><label class="govuk-label govuk-radios__label" for="type-option0"> Accepted <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option1" value="REJECTED" name="type"><label class="govuk-label govuk-radios__label" for="type-option1"> Rejected <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><div govuk-textarea="" label="Notes (optional)" formcontrolname="notes" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><label class="govuk-label" for="notes" id="l.notes"> Notes (optional)
</label><!--container--><!--container--><textarea class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid" id="notes" name="notes" rows="5"></textarea><!--container--></div><cca-multiple-file-input formcontrolname="files" label="Upload evidence (optional)" class="ng-untouched ng-pristine ng-valid"><div class="cca-multi-file-upload cca-multi-file-upload--enhanced"><div class="govuk-form-group"><label class="govuk-label govuk-label--m" id="l.files" for="files">Upload evidence (optional)</label><span class="govuk-hint" id="files-hint-file-size"> Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. </span><!--container--><!--container--><!--container--><div class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"><input multiple="" type="file" class="govuk-file-upload cca-multi-file-upload__input" accept="*/*" id="files" name="files" aria-labelledby="l.files ld.files"><p class="govuk-body">Drag and drop files here or</p><label class="govuk-button govuk-button--secondary" id="ld.files" for="files"> Choose files </label><div aria-live="polite" role="status" class="govuk-visually-hidden"></div></div></div><cca-file-upload-list><div class="cca-multi-file__uploaded-files cca-hidden"><!--container--><!--container--><dl class="govuk-summary-list"><!--container--></dl><!--container--><!--container--><!--container--><!--container--><!--container--></div><!--container--></cca-file-upload-list></div></cca-multiple-file-input></cca-decision><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step></div><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><netz-return-to-task-or-action-page><a class="govuk-link" href="/undefined"> Return to: Review underlying agreement variation </a></netz-return-to-task-or-action-page>"
