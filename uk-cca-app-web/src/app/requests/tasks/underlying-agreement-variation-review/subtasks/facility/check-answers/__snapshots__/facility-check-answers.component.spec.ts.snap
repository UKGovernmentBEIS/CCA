exports[`FacilityCheckAnswersComponent should show summary values 1`] = `
<cca-facility-check-answers
  activatedRoute={[Function Object]}
  decision={[Function Object]}
  downloadUrl={[Function String]}
  facility={[Function Function]}
  facilityId={[Function String]}
  requestTaskStore={[Function _RequestTaskStore]}
