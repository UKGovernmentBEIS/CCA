              class="govuk-form-group"
            >
              <fieldset
                class="govuk-fieldset"
                govukfieldset=""
                id="type"
              >
                <legend
                  class="govuk-fieldset__legend"
                  govuklegend=""
                  id="l.type"
                >
                  
                  
                </legend>
                
                
                <div
                  class="govuk-radios"
                >
                  
                  <div
                    class="govuk-radios__item"
                  >
