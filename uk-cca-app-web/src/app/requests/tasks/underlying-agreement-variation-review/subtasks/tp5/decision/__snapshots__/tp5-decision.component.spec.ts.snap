          >
            <div
              class="cca-multi-file-upload cca-multi-file-upload--enhanced"
            >
              <div
                class="govuk-form-group"
              >
                <label
                  class="govuk-label govuk-label--m"
                  for="files"
                  id="l.files"
                >
                  Upload evidence (optional)
                </label>
                <span
                  class="govuk-hint"
                  id="files-hint-file-size"
                >
                   Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. 
                </span>
                
                
                
                <div
                  class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"
                >
                  <input
                    accept="*/*"
                    aria-labelledby="l.files ld.files"
                    class="govuk-file-upload cca-multi-file-upload__input"
                    id="files"
                    multiple=""
                    name="files"
                    type="file"
                  />
                  <p
                    class="govuk-body"
                  >
                    Drag and drop files here or
                  </p>
                  <label
                    class="govuk-button govuk-button--secondary"
                    for="files"
                    id="ld.files"
                  >
                     Choose files 
                  </label>
                  <div
                    aria-live="polite"
                    class="govuk-visually-hidden"
                    role="status"
                  >
                    
                  </div>
                </div>
              </div>
              <cca-file-upload-list>
                <div
                  class="cca-multi-file__uploaded-files cca-hidden"
                >
                  
                  
                  <dl
                    class="govuk-summary-list"
                  >
                    
                  </dl>
                  
                  
                  
                  
                  
                </div>
                
              </cca-file-upload-list>
            </div>
          </cca-multiple-file-input>
        </cca-decision>
        <button
          class="govuk-button"
          govukbutton=""
          netzpendingbutton=""
          type="submit"
        >
          Continue
        </button>
        
        
      </form>
    </cca-wizard-step>
  </div>
  <hr
    class="govuk-footer__section-break govuk-!-margin-bottom-3"
  />
  <netz-return-to-task-or-action-page>
    <a
      class="govuk-link"
      href="/undefined"
    >
       Return to: Review underlying agreement variation 
    </a>
  </netz-return-to-task-or-action-page>
</div>
`;
