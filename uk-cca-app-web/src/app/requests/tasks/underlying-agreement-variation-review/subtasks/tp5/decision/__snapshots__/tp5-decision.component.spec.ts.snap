        <netz-page-heading>
          
          <h1
            class="govuk-heading-l"
          >
            
          </h1>
        </netz-page-heading>
        <cca-decision>
          <h2
            class="govuk-heading-m"
          >
            What is your decision on the information submitted?
          </h2>
          <span
            class="govuk-hint"
          >
            Use your judgement to make minor changes within the details if needed
          </span>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="type"
            govuk-radio=""
          >
            <div
              class="govuk-form-group"
            >
              <fieldset
                class="govuk-fieldset"
                govukfieldset=""
                id="type"
              >
                <legend
                  class="govuk-fieldset__legend"
                  govuklegend=""
                  id="l.type"
                >
                  
                  
                </legend>
                
                
                <div
                  class="govuk-radios"
                >
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="type-option0"
                      name="type"
                      type="radio"
                      value="ACCEPTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option0"
                    >
                       Accepted 
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="type-option1"
                      name="type"
                      type="radio"
                      value="REJECTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option1"
                    >
                       Rejected 
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                </div>
              </fieldset>
            </div>
          </div>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="notes"
            govuk-textarea=""
            label="Notes (optional)"
          >
            <label
              class="govuk-label"
              for="notes"
              id="l.notes"
            >
               Notes (optional)

            </label>
            
            
            <textarea
              class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid"
              id="notes"
              name="notes"
              rows="5"
            />
            
          </div>
          <cca-multiple-file-input
            class="ng-untouched ng-pristine ng-valid"
            formcontrolname="files"
