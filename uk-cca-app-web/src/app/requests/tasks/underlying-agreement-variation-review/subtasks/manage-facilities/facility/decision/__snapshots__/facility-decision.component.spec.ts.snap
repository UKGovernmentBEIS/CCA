        </dl>
      </div>
    </cca-highlight-diff>
    <cca-wizard-step
      class="ng-untouched ng-pristine ng-valid"
    >
      <form
        class="ng-untouched ng-pristine ng-valid"
        novalidate=""
      >
        
        <netz-page-heading>
          
          <h1
            class="govuk-heading-l"
          >
            
          </h1>
        </netz-page-heading>
        <cca-decision-with-date>
          <h2
            class="govuk-heading-m"
          >
            What is your decision on the information submitted?
          </h2>
          <span
            class="govuk-hint"
          >
            Use your judgement to make minor changes within the details if needed
          </span>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="type"
            govuk-radio=""
          >
            <div
              class="govuk-form-group"
            >
              <fieldset
                class="govuk-fieldset"
                govukfieldset=""
                id="type"
              >
                <legend
                  class="govuk-fieldset__legend"
                  govuklegend=""
                  id="l.type"
                >
                  
                  
                </legend>
                
                
                <div
                  class="govuk-radios"
                >
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="type-option0"
                      name="type"
                      type="radio"
                      value="ACCEPTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option0"
                    >
                       Accepted 
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="type-option1"
                      name="type"
                      type="radio"
                      value="REJECTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option1"
                    >
                       Rejected 
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                </div>
              </fieldset>
            </div>
          </div>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="notes"
            govuk-textarea=""
            label="Notes (optional)"
          >
            <label
              class="govuk-label"
              for="notes"
              id="l.notes"
            >
               Notes (optional)

            </label>
            
            
            <textarea
              class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid"
              id="notes"
              name="notes"
              rows="5"
            />
            
          </div>
          <cca-multiple-file-input
            class="ng-untouched ng-pristine ng-valid"
            formcontrolname="files"
            label="Upload evidence (optional)"
          >
            <div
              class="cca-multi-file-upload cca-multi-file-upload--enhanced"
            >
              <div
                class="govuk-form-group"
              >
                <label
                  class="govuk-label govuk-label--m"
                  for="files"
                  id="l.files"
                >
                  Upload evidence (optional)
                </label>
                <span
                  class="govuk-hint"
                  id="files-hint-file-size"
                >
                   Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. 
                </span>
                
                
                
                <div
                  class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"
                >
                  <input
                    accept="*/*"
                    aria-labelledby="l.files ld.files"
                    class="govuk-file-upload cca-multi-file-upload__input"
                    id="files"
                    multiple=""
                    name="files"
                    type="file"
                  />
                  <p
                    class="govuk-body"
                  >
                    Drag and drop files here or
                  </p>
                  <label
                    class="govuk-button govuk-button--secondary"
                    for="files"
                    id="ld.files"
                  >
                     Choose files 
                  </label>
                  <div
                    aria-live="polite"
                    class="govuk-visually-hidden"
                    role="status"
                  >
                    
                  </div>
                </div>
              </div>
              <cca-file-upload-list>
                <div
                  class="cca-multi-file__uploaded-files cca-hidden"
                >
                  
                  
                  <dl
                    class="govuk-summary-list"
                  >
                    
                  </dl>
                  
                  
                  
                  
                  
                </div>
                
              </cca-file-upload-list>
            </div>
          </cca-multiple-file-input>
        </cca-decision-with-date>
        <button
          class="govuk-button"
          govukbutton=""
          netzpendingbutton=""
          type="submit"
        >
          Continue
        </button>
        
        
      </form>
    </cca-wizard-step>
  </div>
  
  <hr
    class="govuk-footer__section-break govuk-!-margin-bottom-3"
  />
  <a
    class="govuk-link"
    href="/"
  >
     Return to: Manage facilities 
  </a>
</div>
`;
