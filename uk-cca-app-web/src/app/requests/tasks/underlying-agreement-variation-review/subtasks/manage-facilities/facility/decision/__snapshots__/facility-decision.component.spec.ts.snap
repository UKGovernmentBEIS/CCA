hange=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Regulator name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Environment Agency (England)</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/eligibility-details?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Attach a copy of the permit</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>No files provided</span><!--container--><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/eligibility-details?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Extent of the facility</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Manufacturing process description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/manufacturingProcessFile">manufacturingProcessFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Process flow maps</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/processFlowFile">processFlowFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Annotated site plans</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/annotatedSitePlansFile">annotatedSitePlansFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Eligible process description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/eligibleProcessFile">eligibleProcessFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Are any directly associated activities claimed?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Directly associated activities description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/activitiesDescriptionFile">activitiesDescriptionFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/extent?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">70% rule</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in the installation</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>50 %</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/apply-rule?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in relation to 3/7ths provision</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>40 %</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/apply-rule?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in eligible facility</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>70 %</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/apply-rule?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Sub-metered start date</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/apply-rule?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Evidence</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/20/file-download/evidenceFile">evidenceFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/apply-rule?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary><!--container--></div><div class="highlight"></div></cca-highlight-diff><cca-wizard-step class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l"></h1></netz-page-heading><cca-decision-with-date><h2 class="govuk-heading-m">What is your decision on the information submitted?</h2><span class="govuk-hint">Use your judgement to make minor changes within the details if needed</span><div govuk-radio="" formcontrolname="type" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="type" class="govuk-fieldset"><legend govuklegend="" id="l.type" class="govuk-fieldset__legend"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option0" value="ACCEPTED" name="type"><label class="govuk-label govuk-radios__label" for="type-option0"> Accepted <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option1" value="REJECTED" name="type"><label class="govuk-label govuk-radios__label" for="type-option1"> Rejected <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><div govuk-textarea="" label="Notes (optional)" formcontrolname="notes" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><label class="govuk-label" for="notes" id="l.notes"> Notes (optional)
</label><!--container--><!--container--><textarea class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid" id="notes" name="notes" rows="5"></textarea><!--container--></div><cca-multiple-file-input formcontrolname="files" label="Upload evidence (optional)" class="ng-untouched ng-pristine ng-valid"><div class="cca-multi-file-upload cca-multi-file-upload--enhanced"><div class="govuk-form-group"><label class="govuk-label govuk-label--m" id="l.files" for="files">Upload evidence (optional)</label><span class="govuk-hint" id="files-hint-file-size"> Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. </span><!--container--><!--container--><!--container--><div class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"><input multiple="" type="file" class="govuk-file-upload cca-multi-file-upload__input" accept="*/*" id="files" name="files" aria-labelledby="l.files ld.files"><p class="govuk-body">Drag and drop files here or</p><label class="govuk-button govuk-button--secondary" id="ld.files" for="files"> Choose files </label><div aria-live="polite" role="status" class="govuk-visually-hidden"></div></div></div><cca-file-upload-list><div class="cca-multi-file__uploaded-files cca-hidden"><!--container--><!--container--><dl class="govuk-summary-list"><!--container--></dl><!--container--><!--container--><!--container--><!--container--><!--container--></div><!--container--></cca-file-upload-list></div></cca-multiple-file-input></cca-decision-with-date><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step></div><!--container--><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a class="govuk-link" href="/"> Return to: Manage facilities </a>"
`;
