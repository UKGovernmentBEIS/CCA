exports[`BaselineAndTargetsSummaryComponent > should match snapshot for TP6 - RELATIVE agreementMeasurementType 1`] = `"<div><netz-page-heading><span class="govuk-caption-l">TP6 (2024)</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><!--container--><cca-highlight-diff><div class="govuk-!-display-none"><cca-summary><h2 class="govuk-heading-m">Target composition</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target calculator file</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/null/file-download/1b2ae8fe-4322-4b8c-9b2c-03d77b5a8fbb">target_calculator_tp6.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy or carbon units used by the sector</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Energy (kWh)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy or carbon units used by the target unit</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Energy (kWh)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target type for agreement composition</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Relative</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target unit throughput has a unit of</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>GJ</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Details of baseline data</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Is at least 12 months of consecutive baseline data available?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>No</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Enter the date that 12 months of data will be available.</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>12 Dec 2020</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Explain how the target unit fits the greenfield criteria</dt><dd govuksummarylistrowvalue="" class="pre-line g