// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ConfirmationComponent > should show proper content 1`] = `"<div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><govuk-panel><div class="govuk-panel govuk-panel--confirmation"><!--container--><div class="govuk-panel__body">Admin termination notice sent to operator</div></div></govuk-panel><p id="regulatory-reason-content"> You must allow at least 28 days for the operator to appeal before you can start the final decision for the termination workflow. </p><h3 class="govuk-heading-m">What happens next</h3><p> A withdrawal task will now appear in your dashboard. You can withdraw the submission of this termination at any time. </p><!--container--><!--container--><a routerlink="/dashboard" class="govuk-link" href="/dashboard"> Return to: Dashboard </a></div></div>"`;
