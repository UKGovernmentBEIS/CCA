exports[`TrackCorrectiveActionsCheckYourAnswersComponent > should display the correct content 1`] = `"<div><netz-page-heading><span class="govuk-caption-l">Corrective action 1</span><!--container--><h1 class="govuk-heading-l">Check your answers</h1></netz-page-heading><cca-summary><h2 class="govuk-heading-m">Corrective action carried out details</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Are you satisfied the operator carried out this corrective action?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Comments</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Not provided</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary><button netzpendingbutton="" govukbutton="" type="button" class="govuk-button">Confirm and complete</button></div><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a routerlink="../../.." class="govuk-link" href="/"> Return to: Track corrective actions  </a>"`;
