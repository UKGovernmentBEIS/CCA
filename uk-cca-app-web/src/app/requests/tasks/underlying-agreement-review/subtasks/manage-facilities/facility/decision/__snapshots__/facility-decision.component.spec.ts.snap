    </cca-summary>
    <cca-wizard-step
      class="ng-untouched ng-valid ng-dirty"
    >
      <form
        class="ng-untouched ng-valid ng-dirty"
        novalidate=""
      >
        
        <netz-page-heading>
          
          <h1
            class="govuk-heading-l"
          >
            
          </h1>
        </netz-page-heading>
        <cca-decision-with-date>
          <h2
            class="govuk-heading-m"
          >
            What is your decision on the information submitted?
          </h2>
          <span
            class="govuk-hint"
          >
            Use your judgement to make minor changes within the details if needed
          </span>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="type"
            govuk-radio=""
          >
            <div
              class="govuk-form-group"
            >
              <fieldset
                class="govuk-fieldset"
                govukfieldset=""
                id="type"
              >
                <legend
                  class="govuk-fieldset__legend"
                  govuklegend=""
                  id="l.type"
                >
                  
                  
                </legend>
                
                
                <div
                  class="govuk-radios"
                >
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      aria-controls="type-option0-conditional"
                      class="govuk-radios__input"
                      id="type-option0"
                      name="type"
                      type="radio"
                      value="ACCEPTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option0"
                    >
                       Accepted 
                      
                      
                    </label>
                    
                  </div>
                  
                  <div
                    class="govuk-radios__conditional govuk-radios__conditional--hidden"
                    id="type-option0-conditional"
                  >
                    <div
                      class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"
                      formcontrolname="changeDate"
                      govuk-checkboxes=""
                    >
                      <fieldset
                        class="govuk-fieldset"
                        govukfieldset=""
                        id="changeDate"
                      >
                        <legend
                          class="govuk-fieldset__legend govuk-fieldset__legend--l"
                          govuklegend=""
                          id="l.changeDate"
                        >
                          
                          
                        </legend>
                        
                        
                        <div
                          class="govuk-checkboxes"
                        >
                          
                          <div
                            class="govuk-checkboxes__item"
                          >
                            <input
                              aria-controls="changeDate-0conditional"
                              aria-describedby="changeDate-0-item-hint"
                              class="govuk-checkboxes__input"
                              disabled=""
                              id="changeDate-0"
                              name="changeDate"
                              type="checkbox"
                              value="true"
                            />
                            <label
                              class="govuk-label govuk-checkboxes__label"
                              for="changeDate-0"
                            >
                               I want to change the subsistence charge start date from the default. 
                              
                              
                            </label>
                            
                          </div>
                          
                          <div
                            class="govuk-checkboxes__conditional govuk-checkboxes__conditional--hidden"
                            id="changeDate-0conditional"
                          >
                            <div
                              class="govuk-!-display-block govuk-form-group ng-untouched ng-dirty"
                              formcontrolname="startDate"
                              govuk-date-input=""
                              label="Start date of paying the subsistence charge fee"
                            >
                              <fieldset
                                class="govuk-fieldset"
                                govukfieldset=""
                                id="startDate"
                              >
                                <legend
                                  class="govuk-fieldset__legend govuk-fieldset__legend--m"
                                  govuklegend=""
                                  id="l.startDate"
                                >
                                  Start date of paying the subsistence charge fee
                                </legend>
                                
                                
                                <div
                                  class="govuk-date-input ng-untouched ng-pristine"
                                >
                                  
                                  <div
                                    class="govuk-date-input__item"
                                  >
                                    <label
                                      class="govuk-label govuk-date-input__label"
                                      for="startDate-day"
                                    >
                                       Day 
                                    </label>
                                    <input
                                      class="govuk-input govuk-date-input__input govuk-input--width-2 ng-untouched ng-pristine"
                                      disabled=""
                                      formcontrolname="day"
                                      id="startDate-day"
                                      inputmode="numeric"
                                      max="31"
                                      min="1"
                                      name="startDate-day"
                                      type="text"
                                    />
                                  </div>
                                  <div
                                    class="govuk-date-input__item"
                                  >
                                    <label
                                      class="govuk-label govuk-date-input__label"
                                      for="startDate-month"
                                    >
                                       Month 
                                    </label>
                                    <input
                                      class="govuk-input govuk-date-input__input govuk-input--width-2 ng-untouched ng-pristine"
                                      disabled=""
                                      formcontrolname="month"
                                      id="startDate-month"
                                      inputmode="numeric"
                                      max="12"
                                      min="1"
                                      type="text"
                                    />
                                  </div>
                                  <div
                                    class="govuk-date-input__item"
                                  >
                                    <label
                                      class="govuk-label govuk-date-input__label"
                                      for="startDate-year"
                                    >
                                       Year 
                                    </label>
                                    <input
                                      class="govuk-input govuk-date-input__input govuk-input--width-4 ng-untouched ng-pristine"
                                      disabled=""
                                      formcontrolname="year"
                                      id="startDate-year"
                                      inputmode="numeric"
                                      name="startDate-year"
                                      type="text"
                                    />
                                  </div>
                                </div>
                              </fieldset>
                            </div>
                            
                          </div>
                          
                          
                          
                        </div>
                      </fieldset>
                    </div>
                    <govuk-details
                      summary=" More information on the subsistence charge start date "
                    >
                      <details
                        class="govuk-details"
                      >
                        <summary
                          class="govuk-details__summary"
                        >
                          <span
                            class="govuk-details__summary-text"
                          >
                             More information on the subsistence charge start date 
                          </span>
                        </summary>
                        <div
                          class="govuk-details__text"
                        >
                          <p>
                             By default, this facility will become eligible for a subsistence charge fee as soon as their assent to the underlying agreement is uploaded by the administrator. If the facility has already paid for the current year whilst it was part of a previous target unit, you may need to override this default date. 
                          </p>
                          <p>
                            Please note that the subsistence charge period starts on 1 January each year.
                          </p>
                        </div>
                      </details>
                    </govuk-details>
                    
                  </div>
                  
                  
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="type-option1"
                      name="type"
                      type="radio"
                      value="REJECTED"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="type-option1"
                    >
                       Rejected 
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                </div>
              </fieldset>
            </div>
          </div>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"
            formcontrolname="notes"
            govuk-textarea=""
            label="Notes (optional)"
          >
            <label
              class="govuk-label"
              for="notes"
              id="l.notes"
            >
               Notes (optional)

            </label>
            
            
            <textarea
              class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid"
              id="notes"
              name="notes"
              rows="5"
            />
            
          </div>
          <cca-multiple-file-input
            class="ng-untouched ng-pristine ng-valid"
            formcontrolname="files"
            label="Upload evidence (optional)"
          >
            <div
              class="cca-multi-file-upload cca-multi-file-upload--enhanced"
            >
              <div
                class="govuk-form-group"
              >
                <label
                  class="govuk-label govuk-label--m"
                  for="files"
                  id="l.files"
                >
                  Upload evidence (optional)
                </label>
                <span
                  class="govuk-hint"
                  id="files-hint-file-size"
                >
                   Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. 
                </span>
                
                
                
                <div
                  class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"
                >
                  <input
                    accept="*/*"
                    aria-labelledby="l.files ld.files"
                    class="govuk-file-upload cca-multi-file-upload__input"
                    id="files"
                    multiple=""
                    name="files"
                    type="file"
                  />
                  <p
                    class="govuk-body"
                  >
                    Drag and drop files here or
                  </p>
                  <label
                    class="govuk-button govuk-button--secondary"
                    for="files"
                    id="ld.files"
                  >
                     Choose files 
                  </label>
                  <div
                    aria-live="polite"
                    class="govuk-visually-hidden"
                    role="status"
                  >
                    
                  </div>
                </div>
              </div>
              <cca-file-upload-list>
                <div
                  class="cca-multi-file__uploaded-files cca-hidden"
                >
                  
                  
                  <dl
                    class="govuk-summary-list"
                  >
                    
                  </dl>
                  
                  
                  
                  
                  
                </div>
                
              </cca-file-upload-list>
            </div>
          </cca-multiple-file-input>
        </cca-decision-with-date>
        <button
          class="govuk-button"
          govukbutton=""
          netzpendingbutton=""
          type="submit"
        >
          Continue
        </button>
        
        
      </form>
    </cca-wizard-step>
  </div>
  
