rovided</span><!--container--><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">70% rule</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in the installation</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>100 %</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in relation to 3/7ths provision</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in eligible facility</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>100 %</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Sub-metered start date</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Evidence</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/tasks/9/file-download/21d97034-7958-419e-a655-8bc1a2c8f12a">file_example_XLSX_50.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary><cca-wizard-step class="ng-untouched ng-valid ng-dirty"><form novalidate="" class="ng-untouched ng-valid ng-dirty"><!--container--><netz-page-heading><!--container--><h1 class="govuk-heading-l"></h1></netz-page-heading><cca-decision-with-date><h2 class="govuk-heading-m">What is your decision on the information submitted?</h2><span class="govuk-hint">Use your judgement to make minor changes within the details if needed</span><div govuk-radio="" formcontrolname="type" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="type" class="govuk-fieldset"><legend govuklegend="" id="l.type" class="govuk-fieldset__legend"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option0" value="ACCEPTED" aria-controls="type-option0-conditional" name="type"><label class="govuk-label govuk-radios__label" for="type-option0"> Accepted <!--container--><!--container--></label><!--container--></div><!--ng-container--><div class="govuk-radios__conditional govuk-radios__conditional--hidden" id="type-option0-conditional"><div govuk-checkboxes="" formcontrolname="changeDate" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"><fieldset govukfieldset="" id="changeDate" class="govuk-fieldset"><legend govuklegend="" id="l.changeDate" class="govuk-fieldset__legend govuk-fieldset__legend--l"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-checkboxes"><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="changeDate-0" name="changeDate" aria-controls="changeDate-0conditional" aria-describedby="changeDate-0-item-hint" value="true" disabled=""><label class="govuk-label govuk-checkboxes__label" for="changeDate-0"> I want to change the subsistence charge start date from the default. <!--container--><!--container--></label><!--container--></div><!--ng-container--><div class="govuk-checkboxes__conditional govuk-checkboxes__conditional--hidden" id="changeDate-0conditional"><div formcontrolname="startDate" govuk-date-input="" label="Start date of paying the subsistence charge fee" class="govuk-!-display-block govuk-form-group ng-untouched ng-dirty"><fieldset govukfieldset="" id="startDate" class="govuk-fieldset"><legend govuklegend="" id="l.startDate" class="govuk-fieldset__legend govuk-fieldset__legend--m">Start date of paying the subsistence charge fee</legend><!--container--><!--container--><div class="govuk-date-input ng-untouched ng-pristine"><!--container--><div class="govuk-date-input__item"><label class="govuk-label govuk-date-input__label" for="startDate-day"> Day </label><input formcontrolname="day" inputmode="numeric" max="31" min="1" type="text" class="govuk-input govuk-date-input__input govuk-input--width-2 ng-untouched ng-pristine" id="startDate-day" name="startDate-day" disabled=""></div><div class="govuk-date-input__item"><label class="govuk-label govuk-date-input__label" for="startDate-month"> Month </label><input formcontrolname="month" inputmode="numeric" max="12" min="1" type="text" class="govuk-input govuk-date-input__input govuk-input--width-2 ng-untouched ng-pristine" id="startDate-month" disabled=""></div><div class="govuk-date-input__item"><label class="govuk-label govuk-date-input__label" for="startDate-year"> Year </label><input formcontrolname="year" inputmode="numeric" type="text" class="govuk-input govuk-date-input__input govuk-input--width-4 ng-untouched ng-pristine" id="startDate-year" name="startDate-year" disabled=""></div></div></fieldset></div><!--ng-container--></div><!--container--><!--ng-container--><!--container--></div></fieldset></div><govuk-details summary=" More information on the subsistence charge start date "><details class="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text"> More information on the subsistence charge start date </span></summary><div class="govuk-details__text"><p> By default, this facility will become eligible for a subsistence charge fee as soon as their assent to the underlying agreement is uploaded by the administrator. If the facility has already paid for the current year whilst it was part of a previous target unit, you may need to override this default date. </p><p>Please note that the subsistence charge period starts on 1 January each year.</p></div></details></govuk-details><!--ng-container--></div><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="type-option1" value="REJECTED" name="type"><label class="govuk-label govuk-radios__label" for="type-option1"> Rejected <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><div govuk-textarea="" label="Notes (optional)" formcontrolname="notes" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><label class="govuk-label" for="notes" id="l.notes"> Notes (optional)
</label><!--container--><!--container--><textarea class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid" id="notes" name="notes" rows="5"></textarea><!--container--></div><cca-multiple-file-input formcontrolname="files" label="Upload evidence (optional)" class="ng-untouched ng-pristine ng-valid"><div class="cca-multi-file-upload cca-multi-file-upload--enhanced"><div class="govuk-form-group"><label class="govuk-label govuk-label--m" id="l.files" for="files">Upload evidence (optional)</label><span class="govuk-hint" id="files-hint-file-size"> Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. </span><!--container--><!--container--><!--container--><div class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"><input multiple="" type="file" class="govuk-file-upload cca-multi-file-upload__input" accept="*/*" id="files" name="files" aria-labelledby="l.files ld.files"><p class="govuk-body">Drag and drop files here or</p><label class="govuk-button govuk-button--secondary" id="ld.files" for="files"> Choose files </label><div aria-live="polite" role="status" class="govuk-visually-hidden"></div></div></div><cca-file-upload-list><div class="cca-multi-file__uploaded-files cca-hidden"><!--container--><!--container--><dl class="govuk-summary-list"><!--container--></dl><!--container--><!--container--><!--container--><!--container--><!--container--></div><!--container--></cca-file-upload-list></div></cca-multiple-file-input></cca-decision-with-date><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step></div><!--container--><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a routerlink="../.." class="govuk-link" href="/">Return to: Manage facilities</a>"
`;
