"<div><netz-page-heading><span class="govuk-caption-l">Facility 1</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><cca-summary><h2 class="govuk-heading-m">Facility Details</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Facility ID</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>ADS_53-F00007</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Site name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Facility 1</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Are the activities carried out in this facility included in the UK ETS?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>No</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">UK ETS Installation Identifier</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!-