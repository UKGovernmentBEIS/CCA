exports[`Review Target Unit Details Decision > should match snapshot 1`] = `
"<div><div class="govuk-grid-row"><div class="govuk-grid-column-two-thirds"><netz-page-heading><!--container--><h1 class="govuk-heading-l">Target unit details</h1></netz-page-heading></div><div class="govuk-grid-column-one-third govuk-!-padding-top-6"><div class="govuk-form-group"><fieldset class="govuk-fieldset"><div data-module="govuk-checkboxes" class="govuk-checkboxes govuk-checkboxes--small"><div class="govuk-checkboxes__item"><input id="toggleCompaniesHouseDetails" name="toggleCompaniesHouseDetails" type="checkbox" class="govuk-checkboxes__input ng-untouched ng-pristine ng-valid" value="false"><label for="toggleCompaniesHouseDetails" class="govuk-label govuk-checkboxes__label"> Show Companies House details </label></div></div></fieldset></div></div></div><div class="govuk-grid-row"><div class="govuk-!-padding-top-7 govuk-grid-column-full"><cca-summary><h2 class="govuk-heading-m">Target unit details</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Operator name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Flying Company 3</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Operator type</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Limited company</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Company number</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>AB123456</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Reason for not having a registration number</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Subsector</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>SUBSECTOR_1</span><!--container--><!--container--><!--container--><!--container--></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a class="govuk-link" href="/?change=true">Change</a></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Operator address</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Address</dt><dd govuksummarylistrowvalue="" class="govuk-summary-