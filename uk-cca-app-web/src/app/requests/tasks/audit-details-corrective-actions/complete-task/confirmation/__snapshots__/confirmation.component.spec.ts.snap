exports[`AuditDetailsAndCorrectiveActionsConfirmationComponent > should display the correct header and caption 1`] = `"<govuk-panel title="Audit details and corrective actions complete"><div class="govuk-panel govuk-panel--confirmation"><h1 class="govuk-panel__title">Audit details and corrective actions complete</h1><!--container--><div class="govuk-panel__body"> Outcome <br><span style="font-weight: bold;">Corrective actions needed</span></div></div></govuk-panel><h3 class="govuk-heading-m">What happens next</h3><p> A new task, 'Track corrective actions', has been assigned to you. You can review the corrective actions and upload any evidence that they have been completed when you start this task. </p><!--container--><a class="govuk-link" href="/dashboard"> Return to: Dashboard </a>"`;
