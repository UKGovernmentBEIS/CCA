exports[`CorrectiveActionsSummaryComponent > should display the correct content 1`] = `"<netz-page-heading caption="Corrective actions"><span class="govuk-caption-l">Corrective actions</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><cca-corrective-actions-summary-details><dl govuk-summary-list="" data-testid="corrective-actions" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key"> Did the final audit report identify any correcive actions the operator must complete? </dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>Yes</span></dd><dd govuksummarylistrowactions="" class="govuk-summary-list__actions"><a routerlink="../has-actions" class="govuk-link" href="/?change=true">Change</a></dd><!--container--></div><!--container--><!--container--></dl><section class="govuk-!-margin-bottom-9"><div class="utility-panel-container"><div class="govuk-grid-row govuk-!-margin-bottom-4 govuk-!-margin-top-0 utility-panel-header background"><div class="govuk-grid-column-three-quarters govuk-!-padding-left-0">Corrective action 1</div><div class="govuk-grid-column-one-quarter govuk-!-text-align-right govuk-!-padding-right-0"><a routerlink="../actions" class="govuk-link" href="/?change=true"> Change </a><!--container--><span> | </span><a role="button" tabindex="0" class="govuk-link"> Remove </a><!--container--></div></div><dl govuk-summary-list="" style="margin: 5px 5px 35px 5px !important;" data-testid="action-0" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Corrective action details</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><span>ca1</span></dd></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Corrective action deadline</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>01 Jan 2025</span></dd></div><!--container--><!--container--></dl></div></section><section class="govuk-!-margin-bottom-9"><div class="utility-panel-container"><div class="govuk-grid-row govuk-!-margin-bottom-4 govuk-!-margin-top-0 utility-panel-header background"><div class="govuk-grid-column-three-quarters govuk-!-padding-left-0">Corrective action 2</div><div class="govuk-grid-column-one-quarter govuk-!-text-align-right govuk-!-padding-right-0"><a routerlink="../actions" class="govuk-link" href="/?change=true"> Change </a><!--container--><span> | </span><a role="button" tabindex="0" class="govuk-link"> Remove </a><!--container--></div></div><dl govuk-summary-list="" style="margin: 5px 5px 35px 5px !important;" data-testid="action-1" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Corrective action details</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><span>ca2</span></dd></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Corrective action deadline</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>02 Feb 2025</span></dd></div><!--container--><!--container--></dl></div></section><!--container--><!--container--><div class="govuk-grid-row"><div class="govuk-grid-column-full"><button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-9"> Add another corrective action </button></div></div><!--container--></cca-corrective-actions-summary-details><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><netz-return-to-task-or-action-page><a class="govuk-link" href="/undefined"> Return to: Dashboard </a></netz-return-to-task-or-action-page>"`;
