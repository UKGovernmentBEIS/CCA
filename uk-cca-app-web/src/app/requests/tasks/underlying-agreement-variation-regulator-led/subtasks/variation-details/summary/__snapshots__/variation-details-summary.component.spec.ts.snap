// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`VariationDetailsSummaryComponent > should show summary values 1`] = `"<div><netz-page-heading caption="Variation details"><span class="govuk-caption-l">Variation details</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><cca-summary><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Changes that usually require the operator to provide their assent</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Amend the name of the operator/organisation</span><!--container--><br><!--container--><!--container--><span>Amend the address of the operator/organisation</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Changes that don't usually require the operator to provide their assent</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Amend the personal information (name, postal address, email address) for the Responsible person</span><!--container--><br><!--container--><!--container--><span>Amend a facility's base year data due to a review of the 70% rule</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Other</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Any changes not covered by the above</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Explain in more detail what you are changing and the reason for the changes</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>variation details readon</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary></div><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><netz-return-to-task-or-action-page><a class="govuk-link" href="/undefined"> Return to: Dashboard </a></netz-return-to-task-or-action-page>"`;
