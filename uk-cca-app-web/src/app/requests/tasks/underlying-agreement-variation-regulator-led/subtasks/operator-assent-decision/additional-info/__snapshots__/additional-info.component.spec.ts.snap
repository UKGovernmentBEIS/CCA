exports[`ExplanationComponent > should match snapshot for AdditionalInfoComponent 1`] = `
"<div class="govuk-!-width-two-thirds"><cca-wizard-step caption="Determine operator assent" heading="Provide any additional information here to support your decision" class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><span class="govuk-caption-l">Determine operator assent</span><!--container--><h1 class="govuk-heading-l">Provide any additional information here to support your decision</h1></netz-page-heading><div formcontrolname="variationImpactsAgreement" govuk-radio="" legend="Does this variation result in changes to the current underlying agreement?" legendsize="medium" class="govuk-!-margin-top-9 govuk-!-margin-bottom-6 govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="variationImpactsAgreement" class="govuk-fieldset"><legend govuklegend="" id="l.variationImpactsAgreement" class="govuk-fieldset__legend govuk-fieldset__legend--m"> Does this variation result in changes to the current underlying agreement? <!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="variationImpactsAgreement-option0" value="true" aria-describedby="variationImpactsAgreement-option0-item-hint" name="variationImpactsAgreement"><label class="govuk-label govuk-radios__label" for="variationImpactsAgreement-option0"> Yes <!--container--><!--container--></label><div class="govuk-radios__hint govuk-hint" id="variationImpactsAgreement-option0-item-hint">A new version of the underlying agreement wll be generated, even if there are no changes from the current version, and you must upload evidence of the operator's assent</div><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="variationImpactsAgreement-option1" value="false" aria-describedby="variationImpactsAgreement-option1-item-hint" name="variationImpactsAgreement"><label class="govuk-label govuk-radios__label" for="variationImpactsAgreement-option1"> No <!--container--><!--container--></label><div class="govuk-radios__hint govuk-hint" id="variationImpactsAgreement-option1-item-hint">A notification letter will be generated to acknowledge that you have accepted the requested changes, but no new underlying agreement is needed</div><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><h3 class="govuk-heading-m">Additional information (optional)</h3><p class="govuk-hint">This will be included into the official notice</p><!--container--><div govuk-textarea="" formcontrolname="additionalInformation" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><label class="govuk-label govuk-visually-hidden" for="additionalInformation" id="l.additionalInformation"> 
</label><!--container--><!--container--><textarea class="govuk-textarea govuk-!-margin-bottom-1 ng-untouched ng-pristine ng-valid" id="additionalInformation" name="additionalInformation" rows="5"></textarea><!--container--></div><cca-multiple-file-input formcontrolname="files" label="Upload a file (optional)" class="ng-untouched ng-pristine ng-valid"><div class="cca-multi-file-upload cca-multi-file-upload--enhanced"><div class="govuk-form-group"><label class="govuk-label govuk-label--m" id="l.files" for="files">Upload a file (optional)</label><span class="govuk-hint" id="files-hint-file-size"> Your document must be a DOC, DOCX, XLS, XLSX, PPT, PPTX, VSD, VSDX, JPG, JPEG, PDF, PNG, TIF, TXT, DIB, BMP or CSV file, no more than 20MB. </span><!--container--><!--container--><!--container--><div class="cca-multi-file-upload__dropzone govuk-!-margin-top-4"><input multiple="" type="file" class="govuk-file-upload cca-multi-file-upload__input" accept="*/*" id="files" name="files" aria-labelledby="l.files ld.files"><p class="govuk-body">Drag and drop files here or</p><label class="govuk-button govuk-button--secondary" id="ld.files" for="files"> Choose files </label><div aria-live="polite" role="status" class="govuk-visually-hidden"></div></div></div><cca-file-upload-list><div class="cca-multi-file__uploaded-files cca-hidden"><!--container--><!--container--><dl class="govuk-summary-list"><!--container--></dl><!--container--><!--container--><!--container--><!--container--><!--container--></div><!--container--></cca-file-upload-list></div></cca-multiple-file-input><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Continue</button><!--container--><!--container--></form></cca-wizard-step></div><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><netz-return-to-task-or-action-page><a class="govuk-link" href="/undefined"> Return to: Vary the underlying agreement </a></netz-return-to-task-or-action-page>"
