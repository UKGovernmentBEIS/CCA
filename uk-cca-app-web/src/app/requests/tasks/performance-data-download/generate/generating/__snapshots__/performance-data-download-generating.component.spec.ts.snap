exports[`PerformanceDataDownloadGeneratingComponent > should show summary values 1`] = `"<govuk-notification-banner><div aria-labelledby="govuk-notification-banner-title" class="govuk-notification-banner" role="region"><div class="govuk-notification-banner__header"><h2 id="govuk-notification-banner-title" class="govuk-notification-banner__title"></h2></div><div class="govuk-notification-banner__content"><h3 class="govuk-heading-m">Files are being generated</h3><span> This may take several minutes to complete. <br> You can wait or return to the dashboard and click on the task to continue. </span></div></div></govuk-notification-banner><a routerlink="/dashboard" class="govuk-link" href="/dashboard">Return to: Dashboard</a>"`;
