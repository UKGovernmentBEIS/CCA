exports[`PreAuditReasonCompletedDeterminationComponent > should show proper view 1`] = `"<netz-page-heading caption="Pre-audit review determination"><span class="govuk-caption-l">Pre-audit review determination</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><cca-summary><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Review completion date</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>05 May 2025</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Is a more detailed audit of this facility needed?</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Review comments</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>asdsadsadad</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary>"`;
