  requestActionStore={[Function _RequestActionStore]}
  summaryData={[Function Function]}
>
  <cca-summary>
    <h2
      class="govuk-heading-m"
    >
      Details
    </h2>
    <dl
      class="govuk-summary-list govuk-!-margin-bottom-9"
      govuk-summary-list=""
    >
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Uploaded Files
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
          <cca-summary-download-files>
            <a
              class="govuk-link"
              href="/"
              target="_blank"
            >
              CONF-T00008_TPR_TP6_V1.xlsx
            </a>
          </cca-summary-download-files>
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Submission date
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           21 Jan 2025, 12:54pm 
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Submission type
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           Secondary 
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Uploaded version number
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           1 
        </dd>
      </div>
    </dl>
    <h2
      class="govuk-heading-m"
    >
      TP Result
    </h2>
    <dl
      class="govuk-summary-list govuk-!-margin-bottom-9"
      govuk-summary-list=""
    >
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Target period performance (kWh)
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           6,566,713.200 
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Target period improvement %
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           3.786% 
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
        >
          Target period improvement to base year %
        </dt>
        <dd
          class="govuk-summary-list__value"
          govuksummarylistrowvalue=""
        >
           5.641% 
        </dd>
      </div>
      <div
        class="govuk-summary-list__row"
        govuksummarylistrow=""
      >
        <dt
          class="govuk-summary-list__key"
          govuksummarylistrowkey=""
