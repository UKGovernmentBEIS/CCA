// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`VariationDetailsComponent > should match snapshot 1`] = `"<div><netz-page-heading><!--container--><h1 class="govuk-heading-l">Variation details</h1></netz-page-heading><cca-summary><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Changes that don't usually require the operator to provide their assent</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Amend the 70% rule evaluation for one or more facilities</span><!--container--><br><!--container--><!--container--><span>Amend the target currency to change the throughput unit</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Explain in more detail what you are changing and the reason for the changes</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Variation reason</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Decision Summary</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Decision status</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Accepted</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Notes</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>test</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Uploaded files</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>No files provided</span><!--container--><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary></div>"`;
