                      id="agreementCompositionType-option1"
                      name="agreementCompositionType"
                      type="radio"
                      value="RELATIVE"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="agreementCompositionType-option1"
                    >
                      Relative
                      
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="agreementCompositionType-option2"
                      name="agreementCompositionType"
                      type="radio"
                      value="NOVEM"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="agreementCompositionType-option2"
                    >
                      Novem
                      
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  
                </div>
              </fieldset>
            </div>
          </div>
          <govuk-details
            class="govuk-body"
            summary="More information about target types"
          >
            <details
              class="govuk-details"
            >
              <summary
                class="govuk-details__summary"
              >
                <span
                  class="govuk-details__summary-text"
                >
                  More information about target types
                </span>
              </summary>
              <div
                class="govuk-details__text"
              >
                <p>
                  Types of targets:
                </p>
                <p>
                   Numerical improvement targets can be expressed in terms of energy or carbon and can be absolute, relative or Novem. 
                </p>
                <p>
                   An absolute target is a target to reduce the total energy consumed within the target facility for each target period. For example, 10,000,000 kWh. 
                </p>
                <p>
                   A relative target is a target to reduce the energy used to produce each unit of throughput in the target facility. For example, 10,000 kWh/tonne product. 
                </p>
                <p>
                   A Novem target is expressed as the ratio of the target energy consumption to the reference energy, where the reference energy is the energy that would have been consumed in the base year for the same level of throughput and product mix as in the target period. 
                </p>
                <p>
                   Novem targets can be used when a target unit produces two or more products which have very different energy intensities of production or whose throughput is measured in very different units (for example, m2 and litres). This can avoid distortions created by a changing mix of throughput between the baseline period and the target period. 
                </p>
              </div>
            </details>
          </govuk-details>
        </section>
        <section>
          <h2>
            Throughput units
          </h2>
          <div
            cca-text-input=""
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine"
            formcontrolname="sectorAssociationThroughputUnit"
            label="The umbrella agreement uses a throughput unit of"
            widthclass="govuk-!-width-two-thirds"
          >
            <label
              class="govuk-label"
              for="sectorAssociationThroughputUnit"
              id="l.sectorAssociationThroughputUnit"
            >
              The umbrella agreement uses a throughput unit of
              
              
              
            </label>
            
            
            <p
              class="govuk-body"
            >
               tonne 
            </p>
            
            
            
            
          </div>
          <div
            class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"
            formcontrolname="isTargetUnitThroughputMeasured"
            govuk-radio=""
            legend="Is the target unit’s throughput measured in units that differ from the umbrella agreement?"
            widthclass="govuk-!-width-two-thirds"
          >
            <div
              class="govuk-form-group"
            >
              <fieldset
                class="govuk-fieldset"
                govukfieldset=""
                id="isTargetUnitThroughputMeasured"
              >
                <legend
                  class="govuk-fieldset__legend"
                  govuklegend=""
                  id="l.isTargetUnitThroughputMeasured"
                >
                  Is the target unit’s throughput measured in units that differ from the umbrella agreement?
                  
                  
                  
                </legend>
                
                
                <div
                  class="govuk-radios govuk-radios--inline"
                >
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="isTargetUnitThroughputMeasured-option0"
                      name="isTargetUnitThroughputMeasured"
                      type="radio"
                      value="true"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="isTargetUnitThroughputMeasured-option0"
                    >
                      Yes
                      
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  
                  <div
                    class="govuk-radios__item"
                  >
                    <input
                      class="govuk-radios__input"
                      id="isTargetUnitThroughputMeasured-option1"
                      name="isTargetUnitThroughputMeasured"
                      type="radio"
                      value="false"
                    />
                    <label
                      class="govuk-label govuk-radios__label"
                      for="isTargetUnitThroughputMeasured-option1"
                    >
                      No
                      
                      
                      
                    </label>
                    
                  </div>
                  
                  
                  
                  
                  
                </div>
              </fieldset>
            </div>
          </div>
          
          
          
        </section>
        
      </div>
      <button
        ccapendingbutton=""
        class="govuk-button"
        govukbutton=""
        type="submit"
      >
        Continue
      </button>
      
      
    </form>
  </cca-wizard-step>
  <hr
    class="govuk-footer__section-break govuk-!-margin-bottom-3"
  />
  <netz-return-to-task-or-action-page>
    <a
      class="govuk-link"
      govuklink=""
      href="/undefined"
    >
       Return to: Apply for underlying agreement 
    </a>
  </netz-return-to-task-or-action-page>
</div>
`;
