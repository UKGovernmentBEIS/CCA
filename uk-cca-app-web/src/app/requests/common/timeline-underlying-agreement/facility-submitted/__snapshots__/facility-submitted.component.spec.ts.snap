exports[`FacilityComponent > should show summary values > facility-summary 1`] = `"<div><netz-page-heading><span class="govuk-caption-l">Facility 1</span><!--container--><h1 class="govuk-heading-l">Summary</h1></netz-page-heading><cca-summary><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Facility status</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>New</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Facility Details</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Facility ID</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>ADS_1-F00001</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Site name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Facility 1</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Are the activities carried out in this facility included in the UK ETS?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>No</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">UK ETS Installation Identifier</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Application reason</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>New entrant</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Previous facility ID</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Will this facility participate in the CCA3 (2026-2030) scheme?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>No</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Scheme participation</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>CCA2</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Facility address</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Facility Line1</span><!--container--><br><!--container--><!--container--><span>Facility Line2</span><!--container--><br><!--container--><!--container--><span>Facility City</span><!--container--><br><!--container--><!--container--><span>Facility 14</span><!--container--><br><!--container--><!--container--><span>GR</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Facility contact details</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">First name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>FacilityFirst</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Last name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>FacilityLast</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Email address</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>facility@email.com</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Contact address</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Facility Contact Line1</span><!--container--><br><!--container--><!--container--><span>Facility Contact Line2</span><!--container--><br><!--container--><!--container--><span>Facility Contact City</span><!--container--><br><!--container--><!--container--><span>Facility Contact 14</span><!--container--><br><!--container--><!--container--><span>GR</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Phone number</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>UK (44) 1234567890</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">CCA eligibility details and authorisation</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Is the facility adjacent to or connected to an existing CCA facility?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Facility ID of adjacent facility</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>ADS_1-F11111</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Agreement type - eligible under</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Environmental Permitting Regulations (EPR)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Do you hold a current Environmental Permitting Regulations (EPR) authorisation for any activity being carried out in the facility?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Authorisation number</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>authorisation</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Regulator name</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Environment Agency (England)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Attach a copy of the permit</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><span>No files provided</span><!--container--><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Extent of the facility</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Manufacturing process description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">manufacturingProcessFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Process flow maps</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">processFlowFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Annotated site plans</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">annotatedSitePlansFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Eligible process description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">eligibleProcessFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Are any directly associated activities claimed?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Directly associated activities description</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">activitiesDescriptionFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">70% rule</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in the installation</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>50 %</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in relation to 3/7ths provision</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>40 %</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy consumed in eligible facility</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>70 %</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Sub-metered start date</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span></span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Evidence</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/">evidenceFile.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary></div><!--container-->"`;
