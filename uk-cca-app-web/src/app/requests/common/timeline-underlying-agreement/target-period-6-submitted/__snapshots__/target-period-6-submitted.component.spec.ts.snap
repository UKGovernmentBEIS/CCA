exports[`TargetPeriod6Component > should show summary values 1`] = `"<div><netz-page-heading><!--container--><h1 class="govuk-heading-l">TP6 (2024)</h1></netz-page-heading><cca-summary><h2 class="govuk-heading-m">Target composition</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target calculator file</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/file-download/calculatorFile">calculatorFile.xls</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy or carbon units used by the sector</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Energy (kWh)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Energy or carbon units used by the target unit</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Energy (kWh)</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target type for agreement composition</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Relative</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target unit throughput has a unit of</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>GJ</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Details of baseline data</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Is at least 12 months of consecutive baseline data available?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>No</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Enter the date that 12 months of data will be available.</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>12 Dec 2020</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Explain how the target unit fits the greenfield criteria</dt><dd govuksummarylistrowvalue="" class="pre-line govuk-summary-list__value"><!--container--><!--container--><!--container--><span>test</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Evidence</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><cca-summary-download-files><a target="_blank" class="govuk-link" href="/file-download/greenfieldEvidence">greenfieldEvidence.xlsx</a><!--container--><!--container--></cca-summary-download-files><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Baseline kWh for the target unit</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>100</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Have you used the special reporting mechanism to adjust the baseline throughput for any of the facilities in the target unit using combined heat and power (CHP)?</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>Yes</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Baseline throughput (GJ)</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>10</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Performance (kWh/GJ)</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>10</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Baseline energy to carbon factor (kgC/kWh)</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>1</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><h2 class="govuk-heading-m">Targets</h2><!--container--><dl govuk-summary-list="" class="govuk-summary-list govuk-!-margin-bottom-9"><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Improvement (%)</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>0.1</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><div govuksummarylistrow="" class="govuk-summary-list__row"><dt govuksummarylistrowkey="" class="govuk-summary-list__key">Target (kWh/GJ)</dt><dd govuksummarylistrowvalue="" class="govuk-summary-list__value"><!--container--><!--container--><!--container--><span>9</span><!--container--><!--container--><!--container--><!--container--></dd><!--container--><!--container--></div><!--container--><!--container--><!--container--></dl><!--container--><!--container--></cca-summary></div>"`;
