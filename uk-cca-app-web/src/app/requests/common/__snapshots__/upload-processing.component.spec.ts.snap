exports[`PerformanceDataUploadProcessingComponent > should show summary values 1`] = `"<govuk-notification-banner data-testid="upload-processing-banner"><div aria-labelledby="govuk-notification-banner-title" class="govuk-notification-banner" role="region"><div class="govuk-notification-banner__header"><h2 id="govuk-notification-banner-title" class="govuk-notification-banner__title"></h2></div><div class="govuk-notification-banner__content"><h3 class="govuk-heading-m">Your files are being uploaded</h3><p>This page will automatically update once the files are uploaded.</p></div></div></govuk-notification-banner>"`;
