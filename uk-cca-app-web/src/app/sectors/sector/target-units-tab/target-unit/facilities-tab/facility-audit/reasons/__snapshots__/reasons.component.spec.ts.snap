ass="govuk-label govuk-checkboxes__label" for="reasons-2"> Base year data <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="reasons-3" name="reasons" aria-describedby="reasons-3-item-hint" value="REPORTING_DATA"><label class="govuk-label govuk-checkboxes__label" for="reasons-3"> Reporting data <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="reasons-4" name="reasons" aria-describedby="reasons-4-item-hint" value="NON_COMPLIANCE"><label class="govuk-label govuk-checkboxes__label" for="reasons-4"> Non-compliance <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><div class="govuk-checkboxes__divider">or</div><!--container--><div class="govuk-checkboxes__item"><input type="checkbox" class="govuk-checkboxes__input" id="reasons-5" name="reasons" aria-describedby="reasons-5-item-hint" value="OTHER"><label class="govuk-label govuk-checkboxes__label" for="reasons-5"> Other <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div><div govuk-textarea="" label="Comments" labelsize="medium" hint="Provide further details on your reasons for auditing this facility" formcontrolname="comments" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-invalid"><label class="govuk-label govuk-label--m" for="comments" id="l.comments"> Comments
