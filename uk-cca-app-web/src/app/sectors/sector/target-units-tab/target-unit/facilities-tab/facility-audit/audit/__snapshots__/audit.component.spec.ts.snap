// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`AuditComponent > should display correct view 1`] = `"<div class="govuk-!-width-two-thirds"><cca-wizard-step caption="Change" heading="Facility audit" submittext="Save and continue" data-testid="audit-form" class="ng-untouched ng-pristine ng-valid"><form novalidate="" class="ng-untouched ng-pristine ng-valid"><!--container--><netz-page-heading><span class="govuk-caption-l">Change</span><!--container--><h1 class="govuk-heading-l">Facility audit</h1></netz-page-heading><p class="govuk-!-padding-bottom-4"> If a facility is marked for audit it will be shown in the relevant report.<br> To start the audit task, select 'Start an audit task' on the facility details page. </p><h2 class="govuk-heading-m">Should this facility be audited?</h2><div formcontrolname="auditRequired" govuk-radio="" class="govuk-!-display-block govuk-form-group ng-untouched ng-pristine ng-valid"><div class="govuk-form-group"><fieldset govukfieldset="" id="auditRequired" class="govuk-fieldset"><legend govuklegend="" id="l.auditRequired" class="govuk-fieldset__legend"><!--container--><!--container--></legend><!--container--><!--container--><div class="govuk-radios"><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="auditRequired-option0" value="true" name="auditRequired"><label class="govuk-label govuk-radios__label" for="auditRequired-option0"> Yes, an audit is needed <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--><div class="govuk-radios__item"><input type="radio" class="govuk-radios__input" id="auditRequired-option1" value="false" name="auditRequired"><label class="govuk-label govuk-radios__label" for="auditRequired-option1"> No, an audit is not needed <!--container--><!--container--></label><!--container--></div><!--ng-container--><!--container--><!--ng-container--><!--container--></div></fieldset></div></div><button netzpendingbutton="" govukbutton="" type="submit" class="govuk-button">Save and continue</button><!--container--><!--container--></form></cca-wizard-step><hr class="govuk-footer__section-break govuk-!-margin-bottom-3"><a routerlink=".." fragment="audit" class="govuk-link" href="/#audit">Return to: TEST-123</a></div>"`;
