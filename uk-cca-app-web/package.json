{
  "name": "uk-cca-app-web",
  "version": "0.81.0",
  "engines": {
    "node": "^18.10"
  },
  "scripts": {
    "postinstall": "node git-version.js && yarn prebuild",
    "ng": "ng",
    "start": "ng serve",
    "start:govuk-components": "ng build govuk-components --watch --configuration development",
    "start:common": "ng build common --watch",
    "test:govuk-components": "jest --config ./projects/govuk-components/jest.config.js",
    "test:govuk-components:watch": "jest --watch --config ./projects/govuk-components/jest.config.js",
    "test:govuk-components:coverage": "jest --coverage --config ./projects/govuk-components/jest.config.js",
    "test:common": "jest --config ./projects/common/jest.config.js",
    "test": "jest",
    "test:frontend": "jest --config ./src/jest.config.js --silent --logHeapUsage --workerIdleMemoryLimit=1GB",
    "test:frontend:limit": "jest --config ./src/jest.config.js --silent --logHeapUsage --workerIdleMemoryLimit=1GB --maxWorkers=50%",
    "test:frontend:update-snapshots": "jest --config ./src/jest.config.js --silent --logHeapUsage --workerIdleMemoryLimit=1GB --updateSnapshot --maxWorkers=50%",
    "test:frontend:watch": "jest --watch --config ./src/jest.config.js",
    "test:frontend:coverage": "jest --coverage --config ./src/jest.config.js",
    "test:app:coverage": "yarn prebuild && yarn run test:frontend:coverage",
    "test:app:watch": "yarn build:govuk-components && yarn run test:frontend:watch",
    "build:govuk-components": "ng build govuk-components",
    "build:cca-api": "ng build cca-api",
    "build:common": "ng build common",
    "prebuild": "yarn build:govuk-components && yarn build:cca-api && yarn build:common",
    "build": "ng build",
    "prebuild:production": "yarn build:govuk-components && yarn build:cca-api",
    "build:production": "ng build",
    "generate:barrels:api": "barrelsby -d projects/cca-api/src/lib/ -l all -D",
    "generate:prepare-swagger-file": "node update-swagger-file.js",
    "pregenerate:api": "yarn generate:prepare-swagger-file && openapi-generator-cli generate -i projects/cca-api/src/assets/swagger.yaml -o projects/cca-api/src/lib/ -g typescript-angular -c projects/cca-api/openapi-config.yaml --global-property supportingFiles=.openapi-generator-ignore",
    "generate:api": "openapi-generator-cli generate -i projects/cca-api/src/assets/swagger.yaml -o projects/cca-api/src/lib/ -g typescript-angular -c projects/cca-api/openapi-config.yaml --global-property skipFormModel=false",
    "postgenerate:api": "yarn generate:barrels:api && rimraf projects/cca-api/src/lib/.openapi-generator && yarn build:cca-api && ng lint --fix && pretty-quick",
    "analyze": "ng build --source-map --named-chunks && source-map-explorer dist/uk-cca-app-web/*.*.js",
    "lint": "ng lint",
    "release:patch": "yarn version --patch --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:minor": "yarn version --minor --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:major": "yarn version --major --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky install",
    "sonar": "sonar-scanner",
    "sonar:local": "sonar-scanner -Dsonar.host.url=http://localhost:9000 -Dsonar.login=admin -Dsonar.password=admin",
    "format:all": "prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.4",
    "@angular/common": "^17.3.4",
    "@angular/compiler": "^17.3.4",
    "@angular/core": "^17.3.4",
    "@angular/forms": "^17.3.4",
    "@angular/platform-browser": "^17.3.4",
    "@angular/platform-browser-dynamic": "^17.3.4",
    "@angular/router": "^17.3.4",
    "@ministryofjustice/frontend": "^0.2.6",
    "@w11k/git-info": "^1.1.2",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "angular-password-strength-meter": "^11.0.0",
    "bignumber.js": "~9.1.1",
    "clean-deep": "^3.4.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "dialog-polyfill": "^0.5.6",
    "google-libphonenumber": "^3.2.34",
    "html-diff-ts": "^1.4.2",
    "immer": "^9.0.21",
    "keycloak-angular": "~15.3.0",
    "keycloak-js": "~25.0.1",
    "lodash-es": "^4.17.21",
    "rxjs": "~7.8.1",
    "sonar-scanner": "^3.1.0",
    "tslib": "^2.6.2",
    "xlsx": "^0.18.5",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-builders/jest": "^17.0.3",
    "@angular-devkit/build-angular": "^17.3.3",
    "@angular-eslint/builder": "^17.3.0",
    "@angular-eslint/eslint-plugin": "^17.3.0",
    "@angular-eslint/eslint-plugin-template": "^17.3.0",
    "@angular-eslint/schematics": "^17.3.0",
    "@angular-eslint/template-parser": "^17.3.0",
    "@angular/cli": "^17.3.3",
    "@angular/compiler-cli": "^17.3.4",
    "@openapitools/openapi-generator-cli": "^2.5.2",
    "@testing-library/angular": "^15.2.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/crypto-js": "^4.2.2",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/gtag.js": "^0.0.12",
    "@types/jest": "^29.5.12",
    "@types/lodash-es": "^4.17.12",
    "@types/marked": "^4.3.2",
    "@types/node": "^18.15.10",
    "@types/papaparse": "^5.3.14",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "axios": "^1.6.8",
    "barrelsby": "^2.8.1",
    "conventional-changelog-cli": "^2.2.2",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.2.3",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "fs-extra": "^10.1.0",
    "git-branch": "^2.0.1",
    "git-describe": "^4.1.1",
    "govuk-frontend": "~5.3.0",
    "husky": "^7.0.4",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.0.3",
    "js-yaml": "^4.1.0",
    "ng-packagr": "^17.3.0",
    "prettier": "^3.2.5",
    "pretty-quick": "^4.0.0",
    "rimraf": "^3.0.2",
    "sass-migrator": "^1.8.1",
    "source-map-explorer": "^2.5.3",
    "ts-jest": "^29.1.2",
    "ts-node": "~10.9.2",
    "typescript": "~5.2.2"
  }
}
