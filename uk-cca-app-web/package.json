{
  "name": "uk-cca-app-web",
  "version": "0.81.0",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "postinstall": "node git-version.js && yarn prebuild",
    "ng": "ng",
    "start": "ng serve",
    "start:govuk-components": "ng build govuk-components --watch --configuration development",
    "start:common": "ng build common --watch",
    "test:govuk-components": "NO_COLOR=1 ng test govuk-components --no-watch",
    "test:govuk-components:local": "ng test govuk-components --no-watch",
    "test:govuk-components:watch": "ng test govuk-components --watch",
    "test:govuk-components:coverage": "ng test govuk-components --no-watch --coverage",
    "test:common": "NO_COLOR=1 ng test common --no-watch",
    "test:common:local": "ng test common --no-watch",
    "test:common:watch": "ng test common",
    "test:common:coverage": "ng test common --no-watch --coverage",
    "test": "ng test --no-watch",
    "test:frontend": "NO_COLOR=1 ng test uk-cca-app-web --no-watch",
    "test:frontend:local": "ng test uk-cca-app-web --no-watch",
    "test:frontend:update-snapshots": "UPDATE_SNAPSHOTS=true ng test uk-cca-app-web --no-watch",
    "test:frontend:watch": "ng test uk-cca-app-web --watch",
    "test:app:coverage": "ng test uk-cca-app-web --no-watch --coverage",
    "build:client": "ng build uk-cca-app-web",
    "build:govuk-components": "ng build govuk-components",
    "build:cca-api": "ng build cca-api",
    "build:common": "ng build common",
    "prebuild": "yarn build:govuk-components && yarn build:cca-api && yarn build:common",
    "build": "ng build",
    "prebuild:production": "yarn build:govuk-components && yarn build:cca-api",
    "build:production": "ng build",
    "generate:barrels:api": "barrelsby -d projects/cca-api/src/lib/ -l all -D",
    "generate:prepare-swagger-file": "node update-swagger-file.js",
    "pregenerate:api": "rimraf projects/cca-api/src/lib && yarn generate:prepare-swagger-file && openapi-generator-cli generate -i projects/cca-api/src/assets/swagger.yaml -o projects/cca-api/src/lib/ -g typescript-angular -c projects/cca-api/openapi-config.yaml --global-property supportingFiles=.openapi-generator-ignore",
    "generate:api": "openapi-generator-cli generate -i projects/cca-api/src/assets/swagger.yaml -o projects/cca-api/src/lib/ -g typescript-angular -c projects/cca-api/openapi-config.yaml --global-property skipFormModel=false",
    "postgenerate:api": "yarn generate:barrels:api && yarn build:cca-api && ng lint --fix && yarn format:cca-api",
    "analyze": "ng build --source-map --named-chunks && source-map-explorer dist/uk-cca-app-web/*.*.js",
    "lint": "ng lint",
    "release:patch": "yarn version --patch --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:minor": "yarn version --minor --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "release:major": "yarn version --major --no-commit-hooks --no-git-tag-version && conventional-changelog -p angular -i CHANGELOG.md -s",
    "sonar": "sonar-scanner",
    "format:all": "prettier --write .",
    "format:cca-api": "prettier --write projects/cca-api/src/lib",
    "format:check": "prettier . --check"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "bignumber.js": "~11.1.5",
    "date-fns": "~4.4.0",
    "google-libphonenumber": "^3.2.44",
    "html-diff-ts": "^1.4.2",
    "immer": "^11.1.11",
    "keycloak-js": "~25.0.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@eslint/js": "^9.39.4",
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/govuk-frontend": "^5.11.0",
    "@types/node": "~25.6.2",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "21.4.0",
    "barrelsby": "^2.8.1",
    "eslint": "^9.39.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fs-extra": "~11.3.6",
    "git-branch": "^2.0.1",
    "git-describe": "^4.1.1",
    "govuk-frontend": "^5.14.0",
    "js-yaml": "^4.3.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "^21.2.5",
    "prettier": "^3.9.5",
    "rimraf": "~6.1.3",
    "sonar-scanner": "^3.1.0",
    "source-map-explorer": "^2.5.3",
    "ts-node": "~10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
